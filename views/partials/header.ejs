<!DOCTYPE html>
<html lang="vi">

<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Sở Y Tế Tây Ninh - Hệ Thống Nhập Số Liệu Khám Sức Khỏe</title>
  <link rel="stylesheet" href="/css/style.css?v=13">
  <script>
    // Immediately apply theme before document parses to prevent page flashing
    const savedTheme = localStorage.getItem('theme');
    if (savedTheme !== 'dark') {
      document.documentElement.classList.add('light-theme');
    }
  </script>
  <!-- ChartJS CDN for charts -->
  <script src="https://cdn.jsdelivr.net/npm/chart.js"></script>
  <!-- SheetJS CDN for Excel exports -->
  <script src="https://cdn.jsdelivr.net/npm/xlsx@0.18.5/dist/xlsx.full.min.js"></script>
  <!-- ExcelJS CDN for styled native .xlsx exports -->
  <script src="https://cdn.jsdelivr.net/npm/exceljs@4.4.0/dist/exceljs.min.js"></script>
</head>

<body class="<%= path === '/login' ? 'login-body' : '' %>">

  <% if (path !=='/login' ) { %>
    <header>
      <div class="container navbar">
        <a href="/" class="nav-brand">
          <!-- Medical Heart/Cross SVG -->
          <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor"
            stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <path
              d="M19 14c1.49-1.46 3-3.21 3-5.5A5.5 5.5 0 0 0 16.5 3c-1.76 0-3 .5-4.5 2-1.5-1.5-2.74-2-4.5-2A5.5 5.5 0 0 0 2 8.5c0 2.3 1.5 4.05 3 5.5l7 7Z" />
            <line x1="12" y1="9" x2="12" y2="15" />
            <line x1="9" y1="12" x2="15" y2="12" />
          </svg>
          <span>Sở Y Tế Tây Ninh</span>
        </a>

        <!-- Mobile menu toggle button -->
        <button class="menu-toggle" id="menu-toggle" aria-label="Mở menu">
          <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"
            stroke-linejoin="round">
            <line x1="4" y1="12" x2="20" y2="12" class="line-mid"></line>
            <line x1="4" y1="6" x2="20" y2="6" class="line-top"></line>
            <line x1="4" y1="18" x2="20" y2="18" class="line-bot"></line>
          </svg>
        </button>

        <div class="nav-backdrop" id="nav-backdrop"></div>

        <ul class="nav-menu" id="nav-menu">
          <li>
            <a href="/" class="nav-link <%= path === '/' ? 'active' : '' %>">
              <svg class="icon-inline" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <rect x="3" y="3" width="7" height="9" />
                <rect x="14" y="3" width="7" height="5" />
                <rect x="14" y="12" width="7" height="9" />
                <rect x="3" y="16" width="7" height="5" />
              </svg>
              Tổng quan
            </a>
          </li>
          <% if (session && session.userId) { %>
            <li>
              <a href="/input" class="nav-link <%= path === '/input' ? 'active' : '' %>">
                <svg class="icon-inline" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                  stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                  <path d="M12 20h9" />
                  <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
                </svg>
                Nhập số liệu
              </a>
            </li>
            <% } %>

              <% if (session && session.userRole==='admin' ) { %>
                <li class="dropdown">
                  <a href="#"
                    class="nav-link <%= (path === '/admin/units' || path === '/admin/centers' || path === '/admin/targets' || path === '/admin/config' || path === '/admin/logs') ? 'active' : '' %>"
                    style="cursor: pointer;">
                    <svg class="icon-inline" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                      <rect x="2" y="7" width="20" height="14" rx="2" ry="2" />
                      <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16" />
                    </svg>
                    Quản lý
                    <svg class="chevron-icon" width="10" height="10" viewBox="0 0 24 24" fill="none"
                      stroke="currentColor" stroke-width="3" style="margin-left: 0.2rem; margin-top: 2px;">
                      <polyline points="6 9 12 15 18 9" />
                    </svg>
                  </a>
                  <div class="dropdown-menu">
                    <a href="/admin/units" class="dropdown-item <%= path === '/admin/units' ? 'active' : '' %>">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.25rem;">
                        <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
                        <circle cx="9" cy="7" r="4" />
                        <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
                        <path d="M16 3.13a4 4 0 0 1 0 7.75" />
                      </svg>
                      Tài khoản Đơn vị
                    </a>
                    <a href="/admin/centers" class="dropdown-item <%= path === '/admin/centers' ? 'active' : '' %>">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.25rem;">
                        <rect x="4" y="2" width="16" height="20" rx="2" ry="2" />
                        <line x1="9" y1="22" x2="9" y2="16" />
                        <line x1="15" y1="22" x2="15" y2="16" />
                        <line x1="9" y1="16" x2="15" y2="16" />
                      </svg>
                      Trạm Y tế
                    </a>
                    <a href="/admin/targets" class="dropdown-item <%= path === '/admin/targets' ? 'active' : '' %>">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.25rem;">
                        <circle cx="12" cy="12" r="3" />
                        <path
                          d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
                      </svg>
                      Cấu hình chỉ tiêu
                    </a>
                    <a href="/admin/config" class="dropdown-item <%= path === '/admin/config' ? 'active' : '' %>">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.25rem;">
                        <circle cx="12" cy="12" r="3" />
                        <path
                          d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
                      </svg>
                      Cấu hình hệ thống
                    </a>
                    <a href="/admin/logs" class="dropdown-item <%= path === '/admin/logs' ? 'active' : '' %>">
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                        stroke-linecap="round" stroke-linejoin="round" style="margin-right: 0.25rem;">
                        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                        <polyline points="14 2 14 8 20 8" />
                        <line x1="16" y1="13" x2="8" y2="13" />
                        <line x1="16" y1="17" x2="8" y2="17" />
                        <polyline points="10 9 9 9 8 9" />
                      </svg>
                      Lịch sử logs
                    </a>
                  </div>
                </li>
                <% } %>

                  <!-- Theme Toggle Button -->
                  <li class="nav-theme-toggle" style="display: flex; align-items: center; margin-right: 0.5rem;">
                    <button id="theme-toggle" class="btn btn-secondary btn-icon"
                      style="padding: 0; border-radius: 50%; width: 34px; height: 34px; display: flex; justify-content: center; align-items: center; cursor: pointer; border: 1px solid var(--panel-border); background: var(--input-bg);"
                      title="Chuyển chế độ Sáng/Tối">
                      <svg id="theme-toggle-sun" class="icon-inline" style="margin: 0; color: var(--accent-yellow);"
                        width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <circle cx="12" cy="12" r="5" />
                        <line x1="12" y1="1" x2="12" y2="3" />
                        <line x1="12" y1="21" x2="12" y2="23" />
                        <line x1="4.22" y1="4.22" x2="5.64" y2="5.64" />
                        <line x1="18.36" y1="18.36" x2="19.78" y2="19.78" />
                        <line x1="1" y1="12" x2="3" y2="12" />
                        <line x1="21" y1="12" x2="23" y2="12" />
                        <line x1="4.22" y1="19.78" x2="5.64" y2="18.36" />
                        <line x1="18.36" y1="5.64" x2="19.78" y2="4.22" />
                      </svg>
                      <svg id="theme-toggle-moon" class="icon-inline" style="margin: 0; color: #4facfe; display: none;"
                        width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                        <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
                      </svg>
                    </button>
                  </li>

                  <% if (session && session.userId) { %>
                    <li>
                      <a href="/profile" class="nav-link <%= path === '/profile' ? 'active' : '' %>">
                        <svg class="icon-inline" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none"
                          stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                          <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                          <circle cx="12" cy="7" r="4" />
                        </svg>
                        Tài khoản
                      </a>
                    </li>

                    <li class="user-info-badge">
                      <!-- Person Badge icon -->
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                        stroke-width="2">
                        <path d="M21 21v-2a4 4 0 0 0-4-4H7a4 4 0 0 0-4 4v2" />
                        <circle cx="12" cy="7" r="4" />
                      </svg>
                      <%= session.unitName %> (<%= session.userRole==='admin' ? 'Admin' : 'Đơn vị' %>)
                    </li>

                    <li>
                      <a href="/logout" class="logout-btn">
                        <!-- Logout icon -->
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <path d="M9 21H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h4" />
                          <polyline points="16 17 21 12 16 7" />
                          <line x1="21" y1="12" x2="9" y2="12" />
                        </svg>
                        Đăng xuất
                      </a>
                    </li>
                    <% } else { %>
                      <li>
                        <a href="/login" class="nav-link <%= path === '/login' ? 'active' : '' %>"
                          style="background: rgba(0, 242, 254, 0.15); color: var(--primary-color); border: 1px solid rgba(0, 242, 254, 0.3); border-radius: 4px; padding: 0.4rem 0.8rem; font-weight: 600;">
                          <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                            stroke-width="2" style="margin-right: 0.25rem; vertical-align: middle;">
                            <path d="M15 3h4a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2h-4" />
                            <polyline points="10 17 15 12 10 7" />
                            <line x1="15" y1="12" x2="3" y2="12" />
                          </svg>
                          Đăng nhập
                        </a>
                      </li>
                      <% } %>
        </ul>
      </div>
    </header>

    <script>
      document.addEventListener('DOMContentLoaded', () => {
        const toggleBtn = document.getElementById('theme-toggle');
        const sunIcon = document.getElementById('theme-toggle-sun');
        const moonIcon = document.getElementById('theme-toggle-moon');

        function updateThemeUI() {
          const isLight = document.documentElement.classList.contains('light-theme');
          if (isLight) {
            sunIcon.style.display = 'none';
            moonIcon.style.display = 'block';
          } else {
            sunIcon.style.display = 'block';
            moonIcon.style.display = 'none';
          }
        }

        // Initial state load
        updateThemeUI();

        if (toggleBtn) {
          toggleBtn.addEventListener('click', () => {
            document.documentElement.classList.toggle('light-theme');
            const isLight = document.documentElement.classList.contains('light-theme');
            localStorage.setItem('theme', isLight ? 'light' : 'dark');
            updateThemeUI();

            // Trigger chart theme updates if charts exist on window
            const gridC = isLight ? 'rgba(0, 0, 0, 0.05)' : 'rgba(255, 255, 255, 0.05)';
            const textC = isLight ? '#475569' : '#94a3b8';

            if (window.completionChart) {
              window.completionChart.options.scales.y.grid.color = gridC;
              window.completionChart.options.scales.y.ticks.color = textC;
              window.completionChart.options.scales.x.ticks.color = textC;
              window.completionChart.update();
            }
            if (window.timelineChart) {
              window.timelineChart.options.scales.y.grid.color = gridC;
              window.timelineChart.options.scales.y.ticks.color = textC;
              window.timelineChart.options.scales.x.ticks.color = textC;
              window.timelineChart.update();
            }
          });
        }

        // Mobile menu toggle logic
        const menuToggle = document.getElementById('menu-toggle');
        const navMenu = document.getElementById('nav-menu');
        const navBackdrop = document.getElementById('nav-backdrop');

        function toggleMenu() {
          if (menuToggle && navMenu && navBackdrop) {
            menuToggle.classList.toggle('active');
            navMenu.classList.toggle('open');
            navBackdrop.classList.toggle('active');
            document.body.classList.toggle('no-scroll');
          }
        }

        if (menuToggle && navBackdrop) {
          menuToggle.addEventListener('click', toggleMenu);
          navBackdrop.addEventListener('click', toggleMenu);
        }

        // Close menu when clicking links on mobile
        const navLinks = document.querySelectorAll('.nav-link:not(.dropdown > a), .dropdown-item, .logout-btn');
        navLinks.forEach(link => {
          link.addEventListener('click', () => {
            if (navMenu && navMenu.classList.contains('open')) {
              toggleMenu();
            }
          });
        });

        // Mobile dropdown toggle
        const dropdowns = document.querySelectorAll('.dropdown');
        dropdowns.forEach(dropdown => {
          const link = dropdown.querySelector(':scope > a');
          if (link) {
            link.addEventListener('click', (e) => {
              if (window.innerWidth <= 1024) {
                e.preventDefault();
                dropdown.classList.toggle('open');
              }
            });
          }
        });
      });
    </script>
    <% } %>

      <main class="container">