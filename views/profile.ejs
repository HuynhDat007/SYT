<%- include('partials/header') %>

<div class="page-title-section">
  <h1 class="page-title">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 28px; height: 28px;">
      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
      <circle cx="12" cy="7" r="4"/>
    </svg>
    Quản Lý Thông Tin Tài Khoản
  </h1>
</div>

<!-- Flash alerts -->
<% if (success) { %>
  <div class="alert alert-success">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
    <%= success %>
  </div>
<% } %>

<% if (error) { %>
  <div class="alert alert-error">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <%= error %>
  </div>
<% } %>

<div class="split-1-1">
  
  <!-- Left Side: Profile Info -->
  <div class="glass-panel">
    <h3 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; color: var(--primary-color);">
      <!-- Card SVG -->
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
      </svg>
      Thông Tin Người Nhập Liệu
    </h3>

    <form action="/profile" method="POST">
      
      <div class="form-group">
        <label>Tên đăng nhập (Tài khoản)</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <input type="text" class="form-control" value="<%= profile.username %>" readonly disabled style="background: rgba(15, 23, 42, 0.3); color: var(--text-muted);">
        </div>
        <span style="font-size: 0.8rem; color: var(--text-muted); margin-top: 0.1rem;">Tên đăng nhập được khởi tạo cố định và không thể thay đổi.</span>
      </div>

      <div class="form-group">
        <label>Tên đơn vị quản lý</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 21h18M3 7v14M21 7v14M16 3H8a2 2 0 0 0-2 2v2h12V5a2 2 0 0 0-2-2zM10 12h4M12 10v4"/>
            </svg>
          </div>
          <input type="text" class="form-control" value="<%= profile.unitName %>" readonly disabled style="background: rgba(15, 23, 42, 0.3); color: var(--text-muted);">
        </div>
      </div>

      <div class="form-group">
        <label for="contactName">Họ và tên người nhập liệu</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <input type="text" id="contactName" name="contactName" class="form-control" value="<%= profile.contactName %>" placeholder="Nhập họ và tên..." required>
        </div>
      </div>

      <div class="form-group">
        <label for="contactPhone">Số điện thoại di động</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <input type="text" id="contactPhone" name="contactPhone" class="form-control" value="<%= profile.contactPhone %>" placeholder="Nhập số điện thoại..." required>
        </div>
      </div>

      <div class="form-group">
        <label for="contactEmail">Địa chỉ Email</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <input type="email" id="contactEmail" name="contactEmail" class="form-control" value="<%= profile.contactEmail %>" placeholder="Nhập địa chỉ email..." required>
        </div>
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1rem;">
        Lưu thông tin liên hệ
      </button>
    </form>
  </div>

  <!-- Right Side: Change Password -->
  <div class="glass-panel">
    <h3 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; color: var(--primary-color);">
      <!-- Key SVG -->
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M21 2l-2 2m-7.61 7.61a5.5 5.5 0 1 1-7.778 7.778 5.5 5.5 0 0 1 7.777-7.777zm0 0L15.5 7.5m0 0l3 3L22 7l-3-3m-3.5 3.5L19 4"/>
      </svg>
      Đổi Mật Khẩu Đăng Nhập
    </h3>

    <form action="/profile" method="POST">
      <!-- Hidden fields to avoid clearing contact info when editing password -->
      <input type="hidden" name="contactName" value="<%= profile.contactName %>">
      <input type="hidden" name="contactPhone" value="<%= profile.contactPhone %>">
      <input type="hidden" name="contactEmail" value="<%= profile.contactEmail %>">

      <div class="form-group">
        <label for="password">Mật khẩu mới</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <input type="password" id="password" name="password" class="form-control" placeholder="Mật khẩu mới ít nhất 6 ký tự" minlength="6" required autocomplete="new-password">
        </div>
      </div>

      <div class="form-group">
        <label for="confirmPassword">Xác nhận mật khẩu mới</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="3" y="11" width="18" height="11" rx="2" ry="2"/>
              <path d="M7 11V7a5 5 0 0 1 10 0v4"/>
            </svg>
          </div>
          <input type="password" id="confirmPassword" name="confirmPassword" class="form-control" placeholder="Nhập lại mật khẩu mới..." minlength="6" required autocomplete="new-password">
        </div>
      </div>

      <button type="submit" class="btn btn-secondary" style="width: 100%; margin-top: 1rem;">
        Cập nhật mật khẩu
      </button>
    </form>
    
    <div style="background: rgba(244, 63, 94, 0.05); border: 1px dashed rgba(244, 63, 94, 0.2); padding: 1rem; border-radius: 8px; margin-top: 1.5rem; font-size: 0.85rem; color: var(--text-secondary);">
      <p style="font-weight: 600; color: var(--accent-red); margin-bottom: 0.25rem;">Khuyến cáo bảo mật:</p>
      <p>Nhằm đảm bảo an toàn dữ liệu, các đơn vị cần thay đổi mật khẩu mặc định của Sở Y Tế cấp phát trong lần đăng nhập đầu tiên.</p>
    </div>
  </div>

</div>

<%- include('partials/footer') %>
