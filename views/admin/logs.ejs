<%- include('../partials/header') %>

<div class="page-title-section">
  <h1 class="page-title">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 28px; height: 28px;">
      <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
      <polyline points="14 2 14 8 20 8"/>
      <line x1="16" y1="13" x2="8" y2="13"/>
      <line x1="16" y1="17" x2="8" y2="17"/>
      <polyline points="10 9 9 9 8 9"/>
    </svg>
    Nhật Ký Hoạt Động Hệ Thống
  </h1>
  
  <!-- Log Filters -->
  <form action="/admin/logs" method="GET" class="filter-bar" style="margin-bottom: 0;">
    <div class="filter-bar-left">
      <div class="form-group" style="margin-bottom: 0; flex-direction: row; align-items: center; gap: 0.5rem;">
        <label for="username" style="font-weight: 600; white-space: nowrap;">Tên tài khoản:</label>
        <div class="input-wrapper" style="width: 200px;">
          <div class="input-icon">
            <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <input type="text" id="username" name="username" class="form-control" placeholder="Tên đăng nhập..." value="<%= usernameQuery %>">
        </div>
      </div>

      <div class="form-group" style="margin-bottom: 0; flex-direction: row; align-items: center; gap: 0.5rem;">
        <label for="action" style="font-weight: 600; white-space: nowrap;">Loại thao tác:</label>
        <select name="action" id="action" class="form-control no-icon" style="width: 150px;">
          <option value="">-- Tất cả --</option>
          <option value="CREATE" <%= actionQuery === 'CREATE' ? 'selected' : '' %>>CREATE (Thêm)</option>
          <option value="UPDATE" <%= actionQuery === 'UPDATE' ? 'selected' : '' %>>UPDATE (Sửa)</option>
          <option value="DELETE" <%= actionQuery === 'DELETE' ? 'selected' : '' %>>DELETE (Xóa)</option>
        </select>
      </div>

      <button type="submit" class="btn btn-primary">
        <!-- Search icon -->
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8"/>
          <line x1="21" y1="21" x2="16.65" y2="16.65"/>
        </svg>
        Lọc nhật ký
      </button>
      
      <% if (usernameQuery || actionQuery) { %>
        <a href="/admin/logs" class="btn btn-secondary">Đặt lại</a>
      <% } %>
    </div>
  </form>
</div>

<div class="glass-panel">
  <% if (logs && logs.length > 0) { %>
    <div class="table-responsive">
      <table class="data-table">
        <thead>
          <tr>
            <th>Thời gian</th>
            <th>Tài khoản</th>
            <th>Thao tác</th>
            <th>Loại thực thể</th>
            <th>Chi tiết thay đổi</th>
          </tr>
        </thead>
        <tbody>
          <% logs.forEach(log => { %>
            <tr>
              <td style="white-space: nowrap;"><%= new Date(log.timestamp).toLocaleString('vi-VN') %></td>
              <td><code><%= log.username %></code></td>
              <td>
                <% if (log.action === 'CREATE') { %>
                  <span class="badge badge-success">CREATE</span>
                <% } else if (log.action === 'UPDATE') { %>
                  <span class="badge badge-warning">UPDATE</span>
                <% } else if (log.action === 'DELETE') { %>
                  <span class="badge badge-danger">DELETE</span>
                <% } %>
              </td>
              <td>
                <span class="badge badge-info" style="font-size: 0.7rem;"><%= log.targetType %></span>
              </td>
              <td style="color: var(--text-primary); font-size: 0.9rem;"><%= log.details %></td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>

    <!-- Pagination controls -->
    <% if (totalPages > 1) { %>
      <div class="pagination">
        <% if (currentPage > 1) { %>
          <a href="/admin/logs?page=<%= currentPage - 1 %>&username=<%= usernameQuery %>&action=<%= actionQuery %>" class="pagination-btn">&laquo;</a>
        <% } %>
        
        <% for(let i = 1; i <= totalPages; i++) { %>
          <a href="/admin/logs?page=<%= i %>&username=<%= usernameQuery %>&action=<%= actionQuery %>" class="pagination-btn <%= currentPage === i ? 'active' : '' %>">
            <%= i %>
          </a>
        <% } %>
        
        <% if (currentPage < totalPages) { %>
          <a href="/admin/logs?page=<%= currentPage + 1 %>&username=<%= usernameQuery %>&action=<%= actionQuery %>" class="pagination-btn">&raquo;</a>
        <% } %>
      </div>
    <% } %>

  <% } else { %>
    <div style="text-align: center; padding: 4rem 1rem; color: var(--text-secondary);">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" style="width: 48px; height: 48px; color: var(--text-muted); margin-bottom: 1rem;">
        <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/>
        <polyline points="14 2 14 8 20 8"/>
      </svg>
      <p style="font-weight: 500;">Không tìm thấy nhật ký hoạt động nào khớp với bộ lọc.</p>
    </div>
  <% } %>
</div>

<%- include('../partials/footer') %>
