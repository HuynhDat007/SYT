<%- include('../partials/header') %>

<div class="page-title-section">
  <h1 class="page-title">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 28px; height: 28px;">
      <rect x="4" y="2" width="16" height="20" rx="2" ry="2"/>
      <line x1="9" y1="22" x2="9" y2="16"/>
      <line x1="15" y1="22" x2="15" y2="16"/>
      <line x1="9" y1="16" x2="15" y2="16"/>
    </svg>
    Quản Lý Danh Mục Trạm Y Tế
  </h1>
  
  <div class="input-wrapper" style="max-width: 320px; width: 100%;">
    <div class="input-icon">
      <!-- Search SVG -->
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </div>
    <input type="text" id="center-search" class="form-control" placeholder="Tìm kiếm trạm y tế, xã..." onkeyup="searchCenterTable()">
  </div>
</div>

<!-- Flash messages -->
<% if (success) { %>
  <div class="alert alert-success">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
    <%= success %>
  </div>
<% } %>

<% if (error) { %>
  <div class="alert alert-error">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <%= error %>
  </div>
<% } %>

<div class="split-layout" style="grid-template-columns: 2fr 1fr; align-items: start; gap: 1.5rem;">
  
  <!-- Left Side: Table List -->
  <div class="glass-panel" style="margin-bottom: 0;">
    <h3 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; color: var(--primary-color);">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="8" y1="6" x2="21" y2="6"/>
        <line x1="8" y1="12" x2="21" y2="12"/>
        <line x1="8" y1="18" x2="21" y2="18"/>
        <line x1="3" y1="6" x2="3.01" y2="6"/>
        <line x1="3" y1="12" x2="3.01" y2="12"/>
        <line x1="3" y1="18" x2="3.01" y2="18"/>
      </svg>
      Danh Sách Các Trạm Y Tế
    </h3>
    
    <div class="table-responsive" style="max-height: 550px; overflow-y: auto;">
      <table class="data-table" id="centers-table">
        <thead style="position: sticky; top: 0; background: #0b0f19; z-index: 10; box-shadow: 0 1px 0 var(--panel-border);">
          <tr>
            <th style="width: 60px;">STT</th>
            <th>Tên Trạm Y Tế</th>
            <th>Thuộc Đơn Vị (Xã / Phường)</th>
            <th style="width: 120px; text-align: center;">Thao Tác</th>
          </tr>
        </thead>
        <tbody>
          <% centers.forEach((center, index) => { %>
            <tr>
              <td><%= index + 1 %></td>
              <td style="font-weight: 600; color: var(--text-primary);"><%= center.name %></td>
              <td><%= center.unitId ? center.unitId.unitName : '-' %></td>
              <td>
                <div style="display: flex; gap: 0.5rem; justify-content: center; align-items: center;">
                  <button type="button" class="btn btn-secondary btn-icon" title="Chỉnh sửa trạm y tế" onclick="openEditModal('<%= center._id %>', '<%= center.name %>', '<%= center.unitId ? center.unitId._id.toString() : '' %>')">
                    <!-- Edit Pencil Icon SVG -->
                    <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2">
                      <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/>
                      <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/>
                    </svg>
                  </button>
                  <form action="/admin/centers/delete/<%= center._id %>" method="POST" style="margin: 0; display: inline;" onsubmit="return confirm('Bạn có chắc chắn muốn xóa trạm y tế <%= center.name %>?')">
                    <button type="submit" class="btn btn-secondary btn-icon" title="Xóa trạm y tế">
                      <!-- Trash icon SVG -->
                      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--accent-red)" stroke-width="2">
                        <polyline points="3 6 5 6 21 6"/>
                        <path d="M19 6v14a2 2 0 0 1-2 2H7a2 2 0 0 1-2-2V6m3 0V4a2 2 0 0 1 2-2h4a2 2 0 0 1 2 2v2"/>
                        <line x1="10" y1="11" x2="10" y2="17"/>
                        <line x1="14" y1="11" x2="14" y2="17"/>
                      </svg>
                    </button>
                  </form>
                </div>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>
  
  <!-- Right Side: Add Form -->
  <div class="glass-panel" style="margin-bottom: 0;">
    <h3 style="font-size: 1.15rem; font-weight: 700; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; color: var(--primary-color);">
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <line x1="12" y1="5" x2="12" y2="19"/>
        <line x1="5" y1="12" x2="19" y2="12"/>
      </svg>
      Thêm Trạm Y Tế
    </h3>
    
    <form action="/centers/add" method="POST">
      <!-- Direct back to /admin/centers instead of default /input -->
      <input type="hidden" name="redirect" value="/admin/centers">

      <div class="form-group">
        <label for="newCenterUnitId">Đơn vị (Xã/Phường) quản lý</label>
        <select name="unitId" id="newCenterUnitId" class="form-control no-icon" required>
          <option value="">-- Chọn Đơn vị --</option>
          <% units.forEach(unit => { %>
            <option value="<%= unit._id %>"><%= unit.unitName %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group" style="margin-top: 1rem;">
        <label for="newCenterName">Tên Trạm Y Tế mới</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="4" y="2" width="16" height="20" rx="2" ry="2"/>
              <line x1="9" y1="22" x2="9" y2="16"/>
              <line x1="15" y1="22" x2="15" y2="16"/>
              <line x1="9" y1="16" x2="15" y2="16"/>
            </svg>
          </div>
          <input type="text" id="newCenterName" name="name" class="form-control" placeholder="Ví dụ: Trạm y tế số 1" required>
        </div>
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1.25rem;">
        Thêm Trạm y tế
      </button>
    </form>
  </div>

</div>

<script>
  function searchCenterTable() {
    const input = document.getElementById('center-search');
    const filter = input.value.toUpperCase();
    const table = document.getElementById('centers-table');
    const tr = table.getElementsByTagName('tr');

    for (let i = 1; i < tr.length; i++) {
      const tdName = tr[i].getElementsByTagName('td')[1];
      const tdUnit = tr[i].getElementsByTagName('td')[2];
      if (tdName || tdUnit) {
        const txtValueName = tdName.textContent || tdName.innerText;
        const txtValueUnit = tdUnit.textContent || tdUnit.innerText;
        if (txtValueName.toUpperCase().indexOf(filter) > -1 || txtValueUnit.toUpperCase().indexOf(filter) > -1) {
          tr[i].style.display = '';
        } else {
          tr[i].style.display = 'none';
        }
      }
    }
  }

  function openEditModal(centerId, centerName, unitId) {
    try {
      console.log('openEditModal called:', centerId, centerName, unitId);
      const modal = document.getElementById('edit-center-modal');
      console.log('modal element:', modal);
      document.getElementById('edit-center-id').value = centerId;
      document.getElementById('edit-center-name').value = centerName;
      document.getElementById('edit-center-unitId').value = unitId;
      modal.style.display = 'flex';
      console.log('modal display set to flex');
    } catch (e) {
      console.error('Error opening modal:', e);
    }
  }

  function closeEditModal() {
    document.getElementById('edit-center-modal').style.display = 'none';
  }
</script>

<!-- Modal Dialog for editing clinic details -->
<div id="edit-center-modal" class="modal-overlay" style="display: none;">
  <div class="glass-panel modal-content" style="max-width: 500px; width: 100%; border-top: 4px solid var(--primary-color);">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
      <h3 style="font-size: 1.2rem; font-weight: 700;">Chỉnh Sửa Trạm Y Tế</h3>
      <button class="btn btn-secondary btn-icon" onclick="closeEditModal()" style="padding: 0.25rem; border-radius: 50%;">
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
    
    <form action="/admin/centers/edit" method="POST">
      <input type="hidden" id="edit-center-id" name="id">

      <div class="form-group">
        <label for="edit-center-unitId">Đơn vị (Xã/Phường) quản lý</label>
        <select name="unitId" id="edit-center-unitId" class="form-control no-icon" required>
          <% units.forEach(unit => { %>
            <option value="<%= unit._id %>"><%= unit.unitName %></option>
          <% }) %>
        </select>
      </div>

      <div class="form-group" style="margin-top: 1rem;">
        <label for="edit-center-name">Tên Trạm Y Tế</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <rect x="4" y="2" width="16" height="20" rx="2" ry="2"/>
              <line x1="9" y1="22" x2="9" y2="16"/>
              <line x1="15" y1="22" x2="15" y2="16"/>
              <line x1="9" y1="16" x2="15" y2="16"/>
            </svg>
          </div>
          <input type="text" id="edit-center-name" name="name" class="form-control" placeholder="Tên trạm y tế" required>
        </div>
      </div>

      <button type="submit" class="btn btn-primary" style="width: 100%; margin-top: 1.5rem;">
        Lưu thay đổi
      </button>
    </form>
  </div>
</div>

<%- include('../partials/footer') %>
