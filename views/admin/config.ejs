<%- include('../partials/header') %>

  <div class="page-title-section">
    <h1 class="page-title">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)"
        stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 28px; height: 28px;">
        <circle cx="12" cy="12" r="3" />
        <path
          d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
      </svg>
      Cấu Hình Hệ Thống
    </h1>
  </div>

  <!-- Flash alerts -->
  <% if (success) { %>
    <div class="alert alert-success">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="20 6 9 17 4 12" />
      </svg>
      <%= success %>
    </div>
    <% } %>

      <% if (error) { %>
        <div class="alert alert-error">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <line x1="12" y1="16" x2="12.01" y2="16" />
          </svg>
          <%= error %>
        </div>
        <% } %>

          <div class="glass-panel" style="max-width: 750px; margin: 0 auto 2rem auto;">
            <h3
              style="font-size: 1.15rem; font-weight: 700; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; color: var(--primary-color);">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <circle cx="12" cy="12" r="3" />
                <path
                  d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z" />
              </svg>
              Cấu hình Thông số & Ghi chú Dashboard
            </h3>

            <form action="/admin/dashboard-note-config" method="POST">
              <div class="form-group"
                style="display: flex; flex-direction: row; align-items: center; gap: 0.5rem; cursor: pointer; margin-bottom: 0.75rem;">
                <input type="checkbox" id="allowPastDateInput" name="allowPastDateInput" value="true"
                  <%=allowPastDateInput ? 'checked' : '' %> style="width: 18px; height: 18px; cursor: pointer; margin:
                0;">
                <label for="allowPastDateInput"
                  style="cursor: pointer; margin: 0; user-select: none; font-weight: 600; font-size: 0.9rem; color: var(--text-primary);">Cho
                  phép đơn vị nhập số liệu ngày cũ</label>
              </div>

              <div class="form-group"
                style="display: flex; flex-direction: row; align-items: center; gap: 0.5rem; cursor: pointer; margin-bottom: 0.75rem;">
                <input type="checkbox" id="includeCnldCbccvc" name="includeCnldCbccvc" value="true" <%=includeCnldCbccvc
                  ? 'checked' : '' %> style="width: 18px; height: 18px; cursor: pointer; margin: 0;">
                <label for="includeCnldCbccvc"
                  style="cursor: pointer; margin: 0; user-select: none; font-weight: 600; font-size: 0.9rem; color: var(--text-primary);">Tính
                  CNLĐ và CBCCVC vào tổng khám</label>
              </div>

              <div class="form-group"
                style="display: flex; flex-direction: row; align-items: center; gap: 0.5rem; cursor: pointer; margin-bottom: 0.75rem;">
                <input type="checkbox" id="includeTehs" name="includeTehs" value="true" <%=includeTehs ? 'checked' : ''
                  %>
                style="width: 18px; height: 18px; cursor: pointer; margin: 0;">
                <label for="includeTehs"
                  style="cursor: pointer; margin: 0; user-select: none; font-weight: 600; font-size: 0.9rem; color: var(--text-primary);">Tính
                  TE&HS vào tổng khám</label>
              </div>

              <div class="form-group"
                style="display: flex; flex-direction: row; align-items: center; gap: 0.5rem; cursor: pointer; margin-bottom: 1.25rem;">
                <input type="checkbox" id="noteVisible" name="noteVisible" value="true" <%=dashboardNoteVisible
                  ? 'checked' : '' %>
                style="width: 18px; height: 18px; cursor: pointer; margin: 0;">
                <label for="noteVisible"
                  style="cursor: pointer; margin: 0; user-select: none; font-weight: 600; font-size: 0.9rem; color: var(--text-primary);">Hiển
                  thị ghi chú trên Dashboard</label>
              </div>

              <div class="form-group" style="margin-bottom: 1.25rem;">
                <label
                  style="display: block; margin-bottom: 0.5rem; font-weight: 600; font-size: 0.9rem; color: var(--text-primary);">
                  Cấu hình sắp xếp danh sách 96 xã/phường
                </label>
                <div
                  style="display: flex; flex-direction: column; gap: 0.5rem; background: var(--input-bg); padding: 0.85rem 1rem; border-radius: 8px; border: 1px solid var(--panel-border);">
                  <label
                    style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.9rem; color: var(--text-primary); margin: 0; user-select: none;">
                    <input type="radio" name="unitSortType" value="stt" <%=(typeof unitSortType==='undefined' ||
                      unitSortType==='stt' ) ? 'checked' : '' %>
                    style="width: 16px; height: 16px; cursor: pointer; accent-color: var(--primary-color);">
                    <span>Sắp xếp theo Số thứ tự của đơn vị</span>
                  </label>
                  <label
                    style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.9rem; color: var(--text-primary); margin: 0; user-select: none;">
                    <input type="radio" name="unitSortType" value="cumulative_desc" <%=(typeof unitSortType
                      !=='undefined' && unitSortType==='cumulative_desc' ) ? 'checked' : '' %>
                    style="width: 16px; height: 16px; cursor: pointer; accent-color: var(--primary-color);">
                    <span>Sắp xếp theo số lượng lũy kế cao xuống thấp</span>
                  </label>
                  <label
                    style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.9rem; color: var(--text-primary); margin: 0; user-select: none;">
                    <input type="radio" name="unitSortType" value="cumulative_asc" <%=(typeof unitSortType
                      !=='undefined' && unitSortType==='cumulative_asc' ) ? 'checked' : '' %>
                    style="width: 16px; height: 16px; cursor: pointer; accent-color: var(--primary-color);">
                    <span>Sắp xếp theo số lượng lũy kế thấp lên cao</span>
                  </label>
                  <label
                    style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.9rem; color: var(--text-primary); margin: 0; user-select: none;">
                    <input type="radio" name="unitSortType" value="completion_rate_desc" <%=(typeof unitSortType
                      !=='undefined' && (unitSortType==='completion_rate_desc' || unitSortType==='completion_rate' ))
                      ? 'checked' : '' %>
                    style="width: 16px; height: 16px; cursor: pointer; accent-color: var(--primary-color);">
                    <span>Sắp xếp theo tỷ lệ hoàn thành 90 ngày cao xuống thấp</span>
                  </label>
                  <label
                    style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; font-size: 0.9rem; color: var(--text-primary); margin: 0; user-select: none;">
                    <input type="radio" name="unitSortType" value="completion_rate_asc" <%=(typeof unitSortType
                      !=='undefined' && unitSortType==='completion_rate_asc' ) ? 'checked' : '' %>
                    style="width: 16px; height: 16px; cursor: pointer; accent-color: var(--primary-color);">
                    <span>Sắp xếp theo tỷ lệ hoàn thành 90 ngày thấp lên cao</span>
                  </label>
                </div>
              </div>

              <!-- Admin Config Fields for Campaign Targets & Populations -->
              <div style="display: grid; grid-template-columns: 1fr 1fr; gap: 1rem; margin-bottom: 1.25rem;">
                <div class="form-group" style="margin-bottom: 0;">
                  <label for="grandResidentPopulationConfig"
                    style="display: block; margin-bottom: 0.4rem; font-weight: 600;">Tổng dân số toàn tỉnh</label>
                  <input type="number" id="grandResidentPopulationConfig" name="grandResidentPopulation"
                    class="form-control no-icon" value="<%= grandResidentPopulationConfig %>" required
                    style="background: var(--input-bg); color: var(--text-primary); border: 1px solid var(--panel-border); border-radius: 6px; padding: 0.65rem 0.75rem; width: 100%; box-sizing: border-box;">
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                  <label for="grandFirstHalfCheckedConfig"
                    style="display: block; margin-bottom: 0.4rem; font-weight: 600;">Đã khám 6T đầu năm</label>
                  <input type="number" id="grandFirstHalfCheckedConfig" name="grandFirstHalfChecked"
                    class="form-control no-icon" value="<%= grandFirstHalfCheckedConfig %>" required
                    style="background: var(--input-bg); color: var(--text-primary); border: 1px solid var(--panel-border); border-radius: 6px; padding: 0.65rem 0.75rem; width: 100%; box-sizing: border-box;">
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                  <label for="campaignTargetConfig" style="display: block; margin-bottom: 0.4rem; font-weight: 600;">Số
                    lượng nhóm ưu tiên đã khám</label>
                  <input type="number" id="campaignTargetConfig" name="campaignTarget" class="form-control no-icon"
                    value="<%= campaignTargetConfig %>" required
                    style="background: var(--input-bg); color: var(--text-primary); border: 1px solid var(--panel-border); border-radius: 6px; padding: 0.65rem 0.75rem; width: 100%; box-sizing: border-box;">
                </div>

                <div class="form-group" style="margin-bottom: 0;">
                  <label for="campaignOffsetConfig" style="display: block; margin-bottom: 0.4rem; font-weight: 600;">Sai
                    số điều chỉnh (Trừ bớt)</label>
                  <input type="number" id="campaignOffsetConfig" name="campaignOffset" class="form-control no-icon"
                    value="<%= campaignOffsetConfig %>" required
                    style="background: var(--input-bg); color: var(--text-primary); border: 1px solid var(--panel-border); border-radius: 6px; padding: 0.65rem 0.75rem; width: 100%; box-sizing: border-box;">
                </div>
              </div>

              <div class="form-group" style="margin-bottom: 1.5rem;">
                <label for="noteText" style="display: block; margin-bottom: 0.4rem; font-weight: 600;">Nội dung ghi
                  chú</label>
                <textarea id="noteText" name="noteText" class="form-control" rows="3" required
                  style="background: var(--input-bg); color: var(--text-primary); border: 1px solid var(--panel-border); border-radius: 6px; padding: 0.75rem; width: 100%; font-family: inherit; font-size: 0.9rem; resize: vertical; box-sizing: border-box;"><%= dashboardNoteText %></textarea>
              </div>

              <button type="submit" class="btn btn-primary" style="padding: 0.65rem 2rem; font-weight: 600;">
                Lưu cấu hình
              </button>
            </form>
          </div>

          <%- include('../partials/footer') %>