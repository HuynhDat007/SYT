<%- include('../partials/header') %>

<div class="page-title-section">
  <h1 class="page-title">
    <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 28px; height: 28px;">
      <circle cx="12" cy="12" r="3"/>
      <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
    </svg>
    Cấu Hình Chỉ Tiêu & Thông Tin Các Đơn Vị
  </h1>
  
  <div class="input-wrapper" style="max-width: 320px; width: 100%;">
    <div class="input-icon">
      <!-- Search SVG -->
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <circle cx="11" cy="11" r="8"/>
        <line x1="21" y1="21" x2="16.65" y2="16.65"/>
      </svg>
    </div>
    <input type="text" id="target-search" class="form-control" placeholder="Tìm kiếm đơn vị..." onkeyup="searchTargetTable()">
  </div>
</div>

<!-- Flash messages -->
<% if (success) { %>
  <div class="alert alert-success">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <polyline points="20 6 9 17 4 12"/>
    </svg>
    <%= success %>
  </div>
<% } %>

<% if (error) { %>
  <div class="alert alert-error">
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
      <circle cx="12" cy="12" r="10"/>
      <line x1="12" y1="8" x2="12" y2="12"/>
      <line x1="12" y1="16" x2="12.01" y2="16"/>
    </svg>
    <%= error %>
  </div>
<% } %>

<div class="glass-panel">
  <div class="table-responsive">
    <table class="data-table" id="targets-table">
      <thead>
        <tr>
          <th>STT</th>
          <th>Tên đơn vị (Xã / Phường)</th>
          <th>Tên đăng nhập</th>
          <th>Chỉ tiêu kế hoạch</th>
          <th>Nhân khẩu</th>
          <th>Đã khám 6T</th>
          <th>Người nhập liệu</th>
          <th>SĐT liên hệ</th>
          <th>Email liên hệ</th>
          <th style="width: 100px; text-align: center;">Cấu hình</th>
        </tr>
      </thead>
      <tbody>
        <% units.forEach((unit, index) => { %>
          <tr>
            <td><%= index + 1 %></td>
            <td style="font-weight: 600; color: var(--text-primary);"><%= unit.unitName %></td>
            <td><code><%= unit.username %></code></td>
            <td><strong style="color: var(--primary-color);"><%= unit.planTarget.toLocaleString('vi-VN') %></strong></td>
            <td><strong><%= unit.residentPopulation.toLocaleString('vi-VN') %></strong></td>
            <td><strong><%= unit.firstHalfChecked.toLocaleString('vi-VN') %></strong></td>
            <td><%= unit.contactName || '-' %></td>
            <td><%= unit.contactPhone || '-' %></td>
            <td><%= unit.contactEmail || '-' %></td>
            <td>
              <div style="text-align: center;">
                <button class="btn btn-secondary btn-icon" onclick="openEditModal('<%= unit._id %>', '<%= unit.unitName %>', <%= unit.planTarget %>, <%= unit.residentPopulation %>, <%= unit.firstHalfChecked %>, '<%= unit.contactName || '' %>', '<%= unit.contactPhone || '' %>', '<%= unit.contactEmail || '' %>')">
                  <!-- Cog icon SVG -->
                  <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)" stroke-width="2">
                    <circle cx="12" cy="12" r="3"/>
                    <path d="M19.4 15a1.65 1.65 0 0 0 .33 1.82l.06.06a2 2 0 1 1-2.83 2.83l-.06-.06a1.65 1.65 0 0 0-1.82-.33 1.65 1.65 0 0 0-1 1.51V21a2 2 0 0 1-4 0v-.09A1.65 1.65 0 0 0 9 19.4a1.65 1.65 0 0 0-1.82.33l-.06.06a2 2 0 1 1-2.83-2.83l.06-.06a1.65 1.65 0 0 0 .33-1.82 1.65 1.65 0 0 0-1.51-1H3a2 2 0 0 1 0-4h.09A1.65 1.65 0 0 0 4.6 9a1.65 1.65 0 0 0-.33-1.82l-.06-.06a2 2 0 1 1 2.83-2.83l.06.06a1.65 1.65 0 0 0 1.82.33H9a1.65 1.65 0 0 0 1-1.51V3a2 2 0 0 1 4 0v.09a1.65 1.65 0 0 0 1 1.51 1.65 1.65 0 0 0 1.82-.33l.06-.06a2 2 0 1 1 2.83 2.83l-.06.06a1.65 1.65 0 0 0-.33 1.82V9a1.65 1.65 0 0 0 1.51 1H21a2 2 0 0 1 0 4h-.09a1.65 1.65 0 0 0-1.51 1z"/>
                  </svg>
                </button>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>
</div>

<!-- Modal Dialog box for Targets editing -->
<div id="edit-modal" class="modal-overlay" style="display: none;">
  <div class="glass-panel modal-content" style="max-width: 500px; width: 100%; border-top: 4px solid var(--primary-color);">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
      <h3 style="font-size: 1.2rem; font-weight: 700;" id="modal-title">Cấu hình: Xã</h3>
      <button class="btn btn-secondary btn-icon" onclick="closeEditModal()" style="padding: 0.25rem; border-radius: 50%;">
        <!-- X Close icon SVG -->
        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>

    <form action="/admin/targets" method="POST">
      <input type="hidden" name="unitId" id="modal-unitId">
      
      <div class="form-group">
        <label for="modal-planTarget">Chỉ tiêu lượt khám được giao</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <circle cx="12" cy="12" r="6"/>
              <circle cx="12" cy="12" r="2"/>
            </svg>
          </div>
          <input type="number" name="planTarget" id="modal-planTarget" class="form-control" min="0" required>
        </div>
      </div>

      <div class="form-group">
        <label for="modal-residentPopulation">Số lượng nhân khẩu thường trú</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/>
              <circle cx="9" cy="7" r="4"/>
            </svg>
          </div>
          <input type="number" name="residentPopulation" id="modal-residentPopulation" class="form-control" min="0" required>
        </div>
      </div>

      <div class="form-group">
        <label for="modal-firstHalfChecked">Số người đã khám 6 tháng đầu năm</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <circle cx="12" cy="12" r="10"/>
              <polyline points="12 6 12 12 14 14"/>
            </svg>
          </div>
          <input type="number" name="firstHalfChecked" id="modal-firstHalfChecked" class="form-control" min="0" required>
        </div>
      </div>

      <h4 style="font-size: 0.95rem; font-weight: 600; color: var(--text-secondary); margin: 1.5rem 0 0.5rem 0; border-bottom: 1px solid var(--panel-border); padding-bottom: 0.25rem;">
        Thông tin người nhập liệu
      </h4>

      <div class="form-group">
        <label for="modal-contactName">Họ và tên</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/>
              <circle cx="12" cy="7" r="4"/>
            </svg>
          </div>
          <input type="text" name="contactName" id="modal-contactName" class="form-control" placeholder="Họ tên người đại diện">
        </div>
      </div>

      <div class="form-group">
        <label for="modal-contactPhone">Số điện thoại</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72 12.84 12.84 0 0 0 .7 2.81 2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45 12.84 12.84 0 0 0 2.81.7A2 2 0 0 1 22 16.92z"/>
            </svg>
          </div>
          <input type="text" name="contactPhone" id="modal-contactPhone" class="form-control" placeholder="Số điện thoại liên hệ">
        </div>
      </div>

      <div class="form-group">
        <label for="modal-contactEmail">Địa chỉ Email</label>
        <div class="input-wrapper">
          <div class="input-icon">
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
          </div>
          <input type="email" name="contactEmail" id="modal-contactEmail" class="form-control" placeholder="Email liên hệ">
        </div>
      </div>

      <div style="display: flex; justify-content: flex-end; gap: 0.75rem; margin-top: 1.5rem;">
        <button type="button" class="btn btn-secondary" onclick="closeEditModal()">Hủy</button>
        <button type="submit" class="btn btn-primary">Lưu cấu hình</button>
      </div>
    </form>
  </div>
</div>

<style>
  /* Modal Overlay CSS */
  .modal-overlay {
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    background: rgba(11, 15, 25, 0.7);
    backdrop-filter: blur(8px);
    display: flex;
    justify-content: center;
    align-items: center;
    z-index: 1000;
  }
  .modal-content {
    animation: zoomIn 0.3s ease-out;
  }
  @keyframes zoomIn {
    from { opacity: 0; transform: scale(0.95); }
    to { opacity: 1; transform: scale(1); }
  }
</style>

<script>
  function openEditModal(unitId, unitName, target, population, firstHalf, name, phone, email) {
    document.getElementById('modal-unitId').value = unitId;
    document.getElementById('modal-title').innerText = 'Cấu hình: ' + unitName;
    document.getElementById('modal-planTarget').value = target;
    document.getElementById('modal-residentPopulation').value = population;
    document.getElementById('modal-firstHalfChecked').value = firstHalf;
    document.getElementById('modal-contactName').value = name;
    document.getElementById('modal-contactPhone').value = phone;
    document.getElementById('modal-contactEmail').value = email;
    
    document.getElementById('edit-modal').style.display = 'flex';
  }

  function closeEditModal() {
    document.getElementById('edit-modal').style.display = 'none';
  }

  // Client side Search function for Wards Table
  function searchTargetTable() {
    const input = document.getElementById('target-search');
    const filter = input.value.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[đĐ]/g, 'd');
    const table = document.getElementById('targets-table');
    const tr = table.getElementsByTagName('tr');

    for (let i = 1; i < tr.length; i++) {
      let td = tr[i].getElementsByTagName('td')[1]; // Column index 1 is Ward Name
      if (td) {
        let txtValue = td.textContent || td.innerText;
        let normalizedText = txtValue.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[đĐ]/g, 'd');
        if (normalizedText.indexOf(filter) > -1) {
          tr[i].style.display = "";
        } else {
          tr[i].style.display = "none";
        }
      }
    }
  }
</script>

<%- include('../partials/footer') %>
