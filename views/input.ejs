                    under6: user.role === 'admin' ? r.adminUnder6 : r.under6,
                    from6To18: user.role === 'admin' ? r.adminFrom6To18 : r.from6To18,
                    over18: user.role === 'admin' ? r.adminOver18 : r.over18
                  }))) %>;

