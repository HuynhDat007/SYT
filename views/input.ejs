<%- include('partials/header') %>

  <style>
    .calendar-day-cell {
      aspect-ratio: 1;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      border-radius: 4px;
      font-size: 0.78rem;
      font-weight: 500;
      cursor: pointer;
      position: relative;
      border: 1px solid transparent;
      transition: all 0.2s ease;
      color: var(--text-primary);
    }

    .calendar-day-cell:hover:not(.disabled) {
      background: rgba(0, 242, 254, 0.1);
      border-color: rgba(0, 242, 254, 0.2);
    }

    .calendar-day-cell.selected {
      background: var(--primary-gradient) !important;
      color: #ffffff !important;
      font-weight: 700;
    }

    .calendar-day-cell.disabled {
      color: var(--text-muted) !important;
      opacity: 0.3;
      cursor: not-allowed;
    }

    .calendar-day-cell.has-data::after {
      content: '';
      position: absolute;
      bottom: 3px;
      width: 4px;
      height: 4px;
      border-radius: 50%;
      background: var(--accent-red);
    }

    .calendar-day-cell.selected.has-data::after {
      background: #0b0f19;
    }

    .calendar-day-cell.other-month {
      opacity: 0.15;
    }

    /* Modal styling */
    .modal-overlay {
      position: fixed;
      top: 0;
      left: 0;
      right: 0;
      bottom: 0;
      background: rgba(0, 0, 0, 0.6);
      backdrop-filter: blur(8px);
      display: flex;
      justify-content: center;
      align-items: center;
      z-index: 1000;
      opacity: 0;
      pointer-events: none;
      transition: opacity 0.3s ease;
    }

    .modal-overlay.active {
      opacity: 1;
      pointer-events: auto;
    }

    .modal-content {
      background: var(--panel-bg);
      border: 1px solid var(--panel-border);
      border-radius: 16px;
      width: 95%;
      max-width: 500px;
      max-height: 90vh;
      overflow-y: auto;
      padding: 1.5rem 2rem;
      box-shadow: var(--panel-shadow);
      transform: scale(0.9);
      transition: transform 0.3s ease;
    }

    .modal-overlay.active .modal-content {
      transform: scale(1);
    }

    .modal-header {
      display: flex;
      justify-content: space-between;
      align-items: center;
      margin-bottom: 1.5rem;
      border-bottom: 1px solid var(--panel-border);
      padding-bottom: 0.75rem;
    }

    .modal-close-btn {
      background: transparent;
      border: none;
      cursor: pointer;
      color: var(--text-secondary);
      display: flex;
      align-items: center;
      justify-content: center;
      padding: 0.25rem;
      border-radius: 50%;
      transition: background 0.2s;
    }

    .modal-close-btn:hover {
      background: rgba(255, 255, 255, 0.1);
      color: var(--text-primary);
    }
  </style>

  <div class="page-title-section">
    <h1 class="page-title">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)"
        stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 28px; height: 28px;">
        <path d="M12 20h9" />
        <path d="M16.5 3.5a2.121 2.121 0 0 1 3 3L7 19l-4 1 1-4L16.5 3.5z" />
      </svg>
      Nhập Số Liệu Khám Sức Khỏe Hàng Ngày
    </h1>

  </div>

  <!-- Flash alerts -->
  <% if (success) { %>
    <div class="alert alert-success">
      <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <polyline points="20 6 9 17 4 12" />
      </svg>
      <%= success %>
    </div>
    <% } %>

      <% if (error) { %>
        <div class="alert alert-error">
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <circle cx="12" cy="12" r="10" />
            <line x1="12" y1="8" x2="12" y2="12" />
            <line x1="12" y1="16" x2="12.01" y2="16" />
          </svg>
          <%= error %>
        </div>
        <% } %>

          <!-- Role-based layout separation -->
          <% if (user.role==='admin' ) { %>
            <div style="display: flex; flex-direction: column; gap: 1.5rem; width: 100%;">

              <!-- Table 1: General Reports (Khám chung tại Trạm) -->
              <div class="glass-panel" style="overflow-x: auto;">
                <h3
                  style="font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; display: flex; align-items: center; justify-content: space-between; color: var(--primary-color);">
                  <span style="display: flex; align-items: center; gap: 0.5rem;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <circle cx="12" cy="12" r="10" />
                      <path d="M8 14s1.5 2 4 2 4-2 4-2" />
                    </svg>
                    Khám chung tại Trạm (Tất cả dữ liệu đã nhập)
                  </span>
                  <button class="btn btn-primary" onclick="openGeneralModal()"
                    style="padding: 0.35rem 0.75rem; font-size: 0.8rem; display: flex; align-items: center; gap: 0.25rem; font-weight: 600; border-radius: 6px; cursor: pointer;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2.5">
                      <line x1="12" y1="5" x2="12" y2="19" />
                      <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    Thêm số liệu
                  </button>
                </h3>

                <% const generalReports=reports.filter(r=> !r.adminWorkplace && r.unitId && r.unitId.toString() ===
                  selectedUnitId);
                  const workplaceReports = reports.filter(r => r.adminWorkplace);
                  %>

                  <table class="table" style="width: 100%; border-collapse: collapse; min-width: 600px;">
                    <thead>
                      <tr
                        style="border-bottom: 2px solid var(--panel-border); text-align: left; font-size: 0.78rem; font-weight: 600; color: var(--text-secondary);">
                        <th style="padding: 0.5rem; text-align: center; width: 40px;">STT</th>
                        <th style="padding: 0.5rem; text-align: center; width: 100px;">Ngày khám</th>
                        <th style="padding: 0.5rem;">Cơ sở khám</th>
                        <th style="padding: 0.5rem; text-align: center;">Dưới 6 tuổi</th>
                        <th style="padding: 0.5rem; text-align: center;">Từ 6 - 18</th>
                        <th style="padding: 0.5rem; text-align: center;">Trên 18</th>
                        <th style="padding: 0.5rem; text-align: center;">Tổng cộng</th>
                        <th style="padding: 0.5rem; width: 90px; text-align: center;">Hành động</th>
                      </tr>
                    </thead>
                    <tbody id="general-table-body">
                      <% if (generalReports.length> 0) { %>
                        <% generalReports.forEach((r, idx)=> { %>
                          <% const rTotal=(r.adminUnder6 || 0) + (r.adminFrom6To18 || 0) + (r.adminOver18 || 0); %>
                            <% const rDate=new Date(r.date); const
                              rDateStr=`${String(rDate.getUTCDate()).padStart(2, '0' )}/${String(rDate.getUTCMonth() +
                              1).padStart(2, '0' )}/${rDate.getUTCFullYear()}`; %>
                              <% const rDateVal=`${rDate.getUTCFullYear()}-${String(rDate.getUTCMonth() +
                                1).padStart(2, '0' )}-${String(rDate.getUTCDate()).padStart(2, '0' )}`; %>
                                <tr style="border-bottom: 1px solid var(--panel-border); font-size: 0.82rem;">
                                  <td style="padding: 0.5rem; text-align: center;">
                                    <%= idx + 1 %>
                                  </td>
                                  <td style="padding: 0.5rem; text-align: center; color: var(--text-secondary);">
                                    <%= rDateStr %>
                                  </td>
                                  <td style="padding: 0.5rem;">
                                    <%= r.centerId ? r.centerId.name : '-' %>
                                  </td>
                                  <td style="padding: 0.5rem; text-align: center;">
                                    <%= r.adminUnder6 || 0 %>
                                  </td>
                                  <td style="padding: 0.5rem; text-align: center;">
                                    <%= r.adminFrom6To18 || 0 %>
                                  </td>
                                  <td style="padding: 0.5rem; text-align: center;">
                                    <%= r.adminOver18 || 0 %>
                                  </td>
                                  <td style="padding: 0.5rem; text-align: center;"><strong
                                      style="color: var(--primary-color);">
                                      <%= rTotal %>
                                    </strong></td>
                                  <td style="padding: 0.5rem; text-align: center;">
                                    <div style="display: flex; gap: 0.35rem; justify-content: center;">
                                      <button type="button" class="btn btn-secondary"
                                        style="padding: 0.2rem 0.35rem; font-size: 0.7rem; border-radius: 4px; min-width: auto; height: auto;"
                                        onclick="editAdminGeneralReport('<%= r._id %>', '<%= r.unitId ? r.unitId._id : '' %>', '<%= r.centerId ? r.centerId._id : '' %>', '<%= rDateVal %>', <%= r.adminUnder6 || 0 %>, <%= r.adminFrom6To18 || 0 %>, <%= r.adminOver18 || 0 %>)">
                                        Sửa
                                      </button>
                                      <form action="/input/delete" method="POST"
                                        onsubmit="return confirm('Bạn có chắc chắn muốn xóa bản ghi này?')"
                                        style="margin: 0; display: inline;">
                                        <input type="hidden" name="reportId" value="<%= r._id %>">
                                        <input type="hidden" name="date" value="<%= selectedDateStr %>">
                                        <input type="hidden" name="unitId" value="<%= selectedUnitId %>">
                                        <button type="submit" class="btn btn-danger"
                                          style="padding: 0.2rem 0.35rem; font-size: 0.7rem; border-radius: 4px; min-width: auto; height: auto; background: var(--accent-red); border-color: var(--accent-red);">
                                          Xóa
                                        </button>
                                      </form>
                                    </div>
                                  </td>
                                </tr>
                                <% }) %>
                                  <% } else { %>
                                    <tr>
                                      <td colspan="9"
                                        style="text-align: center; color: var(--text-secondary); padding: 1.5rem 0; font-size: 0.8rem;">
                                        Chưa có số liệu khám chung được nhập.</td>
                                    </tr>
                                    <% } %>
                    </tbody>
                  </table>

                  <div
                    style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; font-size: 0.82rem; color: var(--text-secondary);">
                    <span id="general-page-info">Trang 1 / 1</span>
                    <div style="display: flex; gap: 0.5rem;">
                      <button type="button" class="btn btn-secondary" id="general-prev-btn"
                        style="padding: 0.25rem 0.5rem; font-size: 0.75rem; min-width: auto; height: auto;"
                        onclick="prevPage('general')">Trước</button>
                      <button type="button" class="btn btn-secondary" id="general-next-btn"
                        style="padding: 0.25rem 0.5rem; font-size: 0.75rem; min-width: auto; height: auto;"
                        onclick="nextPage('general')">Sau</button>
                    </div>
                  </div>
              </div>

              <!-- Table 2: Workplace Reports (Khám theo đơn vị KSK) -->
              <div class="glass-panel" style="overflow-x: auto;">
                <h3
                  style="font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; display: flex; align-items: center; justify-content: space-between; color: var(--primary-color);">
                  <span style="display: flex; align-items: center; gap: 0.5rem;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2" />
                      <circle cx="12" cy="7" r="4" />
                    </svg>
                    Khám theo đơn vị KSK (Tất cả dữ liệu đã nhập)
                  </span>
                  <button class="btn btn-primary" onclick="openWorkplaceModal()"
                    style="padding: 0.35rem 0.75rem; font-size: 0.8rem; display: flex; align-items: center; gap: 0.25rem; font-weight: 600; border-radius: 6px; cursor: pointer;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2.5">
                      <line x1="12" y1="5" x2="12" y2="19" />
                      <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    Thêm đơn vị KSK
                  </button>
                </h3>

                <table class="table" style="width: 100%; border-collapse: collapse; min-width: 600px;">
                  <thead>
                    <tr
                      style="border-bottom: 2px solid var(--panel-border); text-align: left; font-size: 0.78rem; font-weight: 600; color: var(--text-secondary);">
                      <th style="padding: 0.5rem; text-align: center; width: 40px;">STT</th>
                      <th style="padding: 0.5rem; text-align: center; width: 100px;">Ngày khám</th>
                      <th style="padding: 0.5rem;">Đơn vị KSK</th>
                      <th style="padding: 0.5rem; text-align: center;">CN/VC/NLĐ</th>
                      <th style="padding: 0.5rem; text-align: center;">Trẻ em</th>
                      <th style="padding: 0.5rem; text-align: center;">HT chính trị</th>
                      <th style="padding: 0.5rem; text-align: center;">Khác</th>
                      <th style="padding: 0.5rem; text-align: center;">Tổng cộng</th>
                      <th style="padding: 0.5rem; width: 90px; text-align: center;">Hành động</th>
                    </tr>
                  </thead>
                  <tbody id="workplace-table-body">
                    <% if (workplaceReports.length> 0) { %>
                      <% workplaceReports.forEach((r, idx)=> { %>
                        <% const rTotal=(r.adminWorkers || 0) + (r.adminChildren || 0) + (r.adminPolitical || 0) +
                          (r.adminOthers || 0); %>
                          <% const rDate=new Date(r.date); const rDateStr=`${String(rDate.getUTCDate()).padStart(2, '0'
                            )}/${String(rDate.getUTCMonth() + 1).padStart(2, '0' )}/${rDate.getUTCFullYear()}`; %>
                            <% const rDateVal=`${rDate.getUTCFullYear()}-${String(rDate.getUTCMonth() +
                              1).padStart(2, '0' )}-${String(rDate.getUTCDate()).padStart(2, '0' )}`; %>
                              <tr style="border-bottom: 1px solid var(--panel-border); font-size: 0.82rem;">
                                <td style="padding: 0.5rem; text-align: center;">
                                  <%= idx + 1 %>
                                </td>
                                <td style="padding: 0.5rem; text-align: center; color: var(--text-secondary);">
                                  <%= rDateStr %>
                                </td>
                                <td style="padding: 0.5rem;">
                                  <strong>
                                    <%= r.adminWorkplace || '-' %>
                                  </strong>
                                  <% if (r.centerId) { %>
                                    <br /><small style="color: var(--text-secondary);">
                                      <%= r.centerId.name %>
                                    </small>
                                    <% } %>
                                </td>
                                <td style="padding: 0.5rem; text-align: center;">
                                  <%= r.adminWorkers || 0 %>
                                </td>
                                <td style="padding: 0.5rem; text-align: center;">
                                  <%= r.adminChildren || 0 %>
                                </td>
                                <td style="padding: 0.5rem; text-align: center;">
                                  <%= r.adminPolitical || 0 %>
                                </td>
                                <td style="padding: 0.5rem; text-align: center;">
                                  <%= r.adminOthers || 0 %>
                                </td>
                                <td style="padding: 0.5rem; text-align: center;"><strong
                                    style="color: var(--primary-color);">
                                    <%= rTotal %>
                                  </strong></td>
                                <td style="padding: 0.5rem; text-align: center;">
                                  <div style="display: flex; gap: 0.35rem; justify-content: center;">
                                    <button type="button" class="btn btn-secondary"
                                      style="padding: 0.2rem 0.35rem; font-size: 0.7rem; border-radius: 4px; min-width: auto; height: auto;"
                                      onclick="editAdminWorkplaceReport('<%= r._id %>', '<%= r.centerId ? r.centerId._id : '' %>', '<%= r.adminWorkplace ? r.adminWorkplace.replace(/'/g, '\\\'').replace(/\"
                                      /g, '\\\"' ) : '' %>', '<%= rDateVal %>', <%= r.adminWorkers || 0 %>, <%=
                                            r.adminChildren || 0 %>, <%= r.adminPolitical || 0 %>, <%= r.adminOthers ||
                                                0 %>)">
                                                Sửa
                                    </button>
                                    <form action="/input/delete" method="POST"
                                      onsubmit="return confirm('Bạn có chắc chắn muốn xóa bản ghi này?')"
                                      style="margin: 0; display: inline;">
                                      <input type="hidden" name="reportId" value="<%= r._id %>">
                                      <input type="hidden" name="date" value="<%= selectedDateStr %>">
                                      <input type="hidden" name="unitId" value="<%= selectedUnitId %>">
                                      <button type="submit" class="btn btn-danger"
                                        style="padding: 0.2rem 0.35rem; font-size: 0.7rem; border-radius: 4px; min-width: auto; height: auto; background: var(--accent-red); border-color: var(--accent-red);">
                                        Xóa
                                      </button>
                                    </form>
                                  </div>
                                </td>
                              </tr>
                              <% }) %>
                                <% } else { %>
                                  <tr>
                                    <td colspan="9"
                                      style="text-align: center; color: var(--text-secondary); padding: 1.5rem 0; font-size: 0.8rem;">
                                      Chưa có số liệu đơn vị KSK được nhập.</td>
                                  </tr>
                                  <% } %>
                  </tbody>
                </table>

                <div
                  style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; font-size: 0.82rem; color: var(--text-secondary);">
                  <span id="workplace-page-info">Trang 1 / 1</span>
                  <div style="display: flex; gap: 0.5rem;">
                    <button type="button" class="btn btn-secondary" id="workplace-prev-btn"
                      style="padding: 0.25rem 0.5rem; font-size: 0.75rem; min-width: auto; height: auto;"
                      onclick="prevPage('workplace')">Trước</button>
                    <button type="button" class="btn btn-secondary" id="workplace-next-btn"
                      style="padding: 0.25rem 0.5rem; font-size: 0.75rem; min-width: auto; height: auto;"
                      onclick="nextPage('workplace')">Sau</button>
                  </div>
                </div>
              </div>

              <!-- Table 3: BYT Linkage Reports (Liên thông cổng BYT) -->
              <div class="glass-panel" style="overflow-x: auto;">
                <h3
                  style="font-size: 1.1rem; font-weight: 700; margin-bottom: 1rem; display: flex; align-items: center; justify-content: space-between; color: var(--primary-color);">
                  <span style="display: flex; align-items: center; gap: 0.5rem;">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71" />
                      <path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71" />
                    </svg>
                    Liên thông cổng BYT (Tất cả dữ liệu đã nhập)
                  </span>
                  <button class="btn btn-primary" onclick="openBytModal()"
                    style="padding: 0.35rem 0.75rem; font-size: 0.8rem; display: flex; align-items: center; gap: 0.25rem; font-weight: 600; border-radius: 6px; cursor: pointer;">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                      stroke-width="2.5">
                      <line x1="12" y1="5" x2="12" y2="19" />
                      <line x1="5" y1="12" x2="19" y2="12" />
                    </svg>
                    Thêm lượt liên thông
                  </button>
                </h3>

                <table class="table" style="width: 100%; border-collapse: collapse; min-width: 600px;">
                  <thead>
                    <tr
                      style="border-bottom: 2px solid var(--panel-border); text-align: left; font-size: 0.78rem; font-weight: 600; color: var(--text-secondary);">
                      <th style="padding: 0.5rem; text-align: center; width: 40px;">STT</th>
                      <th style="padding: 0.5rem; text-align: center; width: 150px;">Ngày liên thông</th>
                      <th style="padding: 0.5rem; text-align: center;">Số lượt liên thông</th>
                      <th style="padding: 0.5rem; text-align: center;">Người cập nhật</th>
                      <th style="padding: 0.5rem; width: 90px; text-align: center;">Hành động</th>
                    </tr>
                  </thead>
                  <tbody id="byt-table-body">
                    <% if (bytLinkages.length> 0) { %>
                      <% bytLinkages.forEach((b, idx)=> { %>
                        <% const bDate=new Date(b.date); const bDateStr=`${String(bDate.getUTCDate()).padStart(2, '0'
                          )}/${String(bDate.getUTCMonth() + 1).padStart(2, '0' )}/${bDate.getUTCFullYear()}`; %>
                          <% const bDateVal=`${bDate.getUTCFullYear()}-${String(bDate.getUTCMonth() + 1).padStart(2, '0'
                            )}-${String(bDate.getUTCDate()).padStart(2, '0' )}`; %>
                            <tr style="border-bottom: 1px solid var(--panel-border); font-size: 0.82rem;">
                              <td style="padding: 0.5rem; text-align: center;">
                                <%= idx + 1 %>
                              </td>
                              <td style="padding: 0.5rem; text-align: center; color: var(--text-secondary);">
                                <%= bDateStr %>
                              </td>
                              <td style="padding: 0.5rem; text-align: center;"><strong
                                  style="color: var(--accent-red);">
                                  <%= b.count.toLocaleString('vi-VN') %>
                                </strong></td>
                              <td style="padding: 0.5rem; text-align: center;">
                                <%= b.updatedBy ? (b.updatedBy.unitName || b.updatedBy.username) : '-' %>
                              </td>
                              <td style="padding: 0.5rem; text-align: center;">
                                <div style="display: flex; gap: 0.35rem; justify-content: center;">
                                  <button type="button" class="btn btn-secondary"
                                    style="padding: 0.2rem 0.35rem; font-size: 0.7rem; border-radius: 4px; min-width: auto; height: auto;"
                                    onclick="editAdminBytLinkage('<%= bDateVal %>', <%= b.count %>)">
                                    Sửa
                                  </button>
                                  <form action="/admin/byt-linkage/delete" method="POST"
                                    onsubmit="return confirm('Bạn có chắc chắn muốn xóa bản ghi này?')"
                                    style="margin: 0; display: inline;">
                                    <input type="hidden" name="linkageId" value="<%= b._id %>">
                                    <input type="hidden" name="date" value="<%= selectedDateStr %>">
                                    <button type="submit" class="btn btn-danger"
                                      style="padding: 0.2rem 0.35rem; font-size: 0.7rem; border-radius: 4px; min-width: auto; height: auto; background: var(--accent-red); border-color: var(--accent-red);">
                                      Xóa
                                    </button>
                                  </form>
                                </div>
                              </td>
                            </tr>
                            <% }) %>
                              <% } else { %>
                                <tr>
                                  <td colspan="5"
                                    style="text-align: center; color: var(--text-secondary); padding: 1.5rem 0; font-size: 0.8rem;">
                                    Chưa có số liệu liên thông cổng BYT được nhập.</td>
                                </tr>
                                <% } %>
                  </tbody>
                </table>

                <div
                  style="display: flex; justify-content: space-between; align-items: center; margin-top: 1rem; font-size: 0.82rem; color: var(--text-secondary);">
                  <span id="byt-page-info">Trang 1 / 1</span>
                  <div style="display: flex; gap: 0.5rem;">
