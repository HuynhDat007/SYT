                    const select = document.getElementById('centerId');
                    if (!select) return;
                    const under6El = document.getElementById('under6');
                    if (!under6El) return; // Skip for Admin form

                    const selectedCenterId = select.value;
                    const matched = existingReports.find(r => r.centerId === selectedCenterId);

