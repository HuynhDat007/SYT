                  function editAdminWorkplaceReport(id, centerId, workplace, dateVal, workers, children, political, others) {
                    document.getElementById('workplaceReportId').value = id;
                    const cSelect = document.getElementById('workplaceCenterId');
                    if (cSelect) cSelect.value = centerId;
                    document.getElementById('workplaceDate').value = dateVal;
                    document.getElementById('workplaceName').value = workplace;
                    document.getElementById('workplaceWorkers').value = workers;
                    document.getElementById('workplaceChildren').value = children;
                    document.getElementById('workplacePolitical').value = political;
                    document.getElementById('workplaceOthers').value = others;

                    document.getElementById('modal-workplace-title').textContent = 'Sửa Số Liệu Đơn Vị KSK';
                    document.getElementById('modal-workplace').classList.add('active');
                  }

                  function editAdminBytLinkage(dateVal, count) {
                    document.getElementById('bytLinkageDate').value = dateVal;
                    document.getElementById('bytLinkageCount').value = count;

                    document.getElementById('modal-byt-title').textContent = 'Sửa Số Lượt Liên Thông BYT';
                    document.getElementById('modal-byt').classList.add('active');
