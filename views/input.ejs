                  function openGeneralModal() {
                    document.getElementById('generalReportId').value = '';
                    const unitSelect = document.getElementById('generalUnitId');
                    if (unitSelect) {
                      unitSelect.value = '';
                      const event = new Event('change');
                      unitSelect.dispatchEvent(event);
                    }

                    const todayStr = new Date().toISOString().substring(0, 10);
                    document.getElementById('generalDate').value = todayStr;
                    document.getElementById('generalCenterId').value = '';
                    document.getElementById('generalUnder6').value = '0';
                    document.getElementById('generalFrom6To18').value = '0';
                    document.getElementById('generalOver18').value = '0';

                    document.getElementById('modal-general-title').textContent = 'Thêm Số Liệu Khám Chung';
                    document.getElementById('modal-general').classList.add('active');
                  }

                  function closeGeneralModal() {
                    document.getElementById('modal-general').classList.remove('active');
                  }

                  function openWorkplaceModal() {
                    document.getElementById('workplaceReportId').value = '';
                    const cSelect = document.getElementById('workplaceCenterId');
                    if (cSelect) cSelect.value = '';
                    const todayStr = new Date().toISOString().substring(0, 10);
                    document.getElementById('workplaceDate').value = todayStr;
                    document.getElementById('workplaceName').value = '';
                    document.getElementById('workplaceWorkers').value = '0';
                    document.getElementById('workplaceChildren').value = '0';
                    document.getElementById('workplacePolitical').value = '0';
                    document.getElementById('workplaceOthers').value = '0';

                    document.getElementById('modal-workplace-title').textContent = 'Thêm Số Liệu Đơn Vị KSK';
                    document.getElementById('modal-workplace').classList.add('active');
                  }

                  function closeWorkplaceModal() {
                    document.getElementById('modal-workplace').classList.remove('active');
                  }

                  function openBytModal() {
                    const todayStr = new Date().toISOString().substring(0, 10);
                    document.getElementById('bytLinkageDate').value = todayStr;
                    document.getElementById('bytLinkageCount').value = '0';

                    document.getElementById('modal-byt-title').textContent = 'Thêm Số Lượt Liên Thông BYT';
                    document.getElementById('modal-byt').classList.add('active');
                  }

                  function closeBytModal() {
                    document.getElementById('modal-byt').classList.remove('active');
                  }
                  // Custom Inline Month Calendar JS
                  const selectedDate = new Date('<%= selectedDateStr %>');
                  let currentYear = selectedDate.getUTCFullYear();
                  let currentMonth = selectedDate.getUTCMonth(); // 0-indexed

                  const allDaysData = <% - JSON.stringify(allDays) %>;
                  const unitIdParam = '<%= user.role === "admin" ? "&unitId=" + selectedUnitId : "" %>';

                  const allDaysMap = {};
                  if (typeof allDaysData !== 'undefined' && allDaysData) {
                    allDaysData.forEach(dayObj => {
                      allDaysMap[dayObj.dateStr] = dayObj.total;
                    });
                  }

                  function drawCalendar() {
                    const monthTitle = document.getElementById('calendar-month-title');
                    const daysGrid = document.getElementById('calendar-days');
                    if (!monthTitle || !daysGrid) return;

                    // Set title
                    monthTitle.innerText = `Tháng ${currentMonth + 1}, ${currentYear}`;

                    // Clear days
                    daysGrid.innerHTML = '';

                    // Get first day of month (e.g. Wednesday)
                    const firstDay = new Date(Date.UTC(currentYear, currentMonth, 1));
                    const firstDayOfWeek = firstDay.getUTCDay(); // 0 (Sun) to 6 (Sat)

                    // Get number of days in current month
                    const totalDays = new Date(Date.UTC(currentYear, currentMonth + 1, 0)).getUTCDate();

                    // Get number of days in previous month for padding
                    const prevMonthTotalDays = new Date(Date.UTC(currentYear, currentMonth, 0)).getUTCDate();

                    // Draw previous month padding days
                    for (let i = firstDayOfWeek - 1; i >= 0; i--) {
                      const cell = document.createElement('div');
                      cell.classList.add('calendar-day-cell', 'disabled', 'other-month');
                      cell.innerText = prevMonthTotalDays - i;
                      daysGrid.appendChild(cell);
                    }

                    // Draw current month days
                    for (let day = 1; day <= totalDays; day++) {
                      const cell = document.createElement('div');
                      cell.classList.add('calendar-day-cell');
                      cell.innerText = day;

                      const mStr = String(currentMonth + 1).padStart(2, '0');
                      const dStr = String(day).padStart(2, '0');
                      const fullDateStr = `${currentYear}-${mStr}-${dStr}`;

                      // Boundaries check: July 1 to Sep 30
                      const cellDate = new Date(Date.UTC(currentYear, currentMonth, day));
                      const minDate = new Date(Date.UTC(2026, 6, 1));
                      const maxDate = new Date(Date.UTC(2026, 8, 30));

                      // Future date check
                      const today = new Date();
                      const todayDate = new Date(Date.UTC(today.getFullYear(), today.getMonth(), today.getDate()));
                      const isFuture = cellDate > todayDate;

                      // Past date check for regular units
                      const isPast = cellDate < todayDate;
                      const isPastRestricted = <%= user.role !== 'admin' %> && !<%= allowPastDateInput %> && isPast;

                      const isDateValid = cellDate >= minDate && cellDate <= maxDate && !isFuture && !isPastRestricted;

                      if (!isDateValid) {
                        cell.classList.add('disabled');
                      } else {
                        // Highlight active selected date
                        if (fullDateStr === '<%= selectedDateStr %>') {
                          cell.classList.add('selected');
                        }

                        // Show green dot indicator if has submitted data
                        if (allDaysMap[fullDateStr] > 0) {
                          cell.classList.add('has-data');
                        }

                        // Click action: navigate to this date
                        cell.addEventListener('click', () => {
                          window.location.href = `/input?date=${fullDateStr}${unitIdParam}`;
                        });
                      }

                      daysGrid.appendChild(cell);
                    }

                    // Next month padding cells to complete the grid
                    const totalRendered = firstDayOfWeek + totalDays;
                    const remaining = 42 - totalRendered;
                    for (let i = 1; i <= remaining; i++) {
                      const cell = document.createElement('div');
                      cell.classList.add('calendar-day-cell', 'disabled', 'other-month');
                      cell.innerText = i;
                      daysGrid.appendChild(cell);
                    }

                    // Limit month navigation bounds: only allow July, Aug, Sept 2026
                    const prevBtn = document.getElementById('prev-month-btn');
                    const nextBtn = document.getElementById('next-month-btn');

                    if (currentYear === 2026 && currentMonth === 6) {
                      prevBtn.disabled = true;
                      prevBtn.style.opacity = '0.3';
                      prevBtn.style.cursor = 'not-allowed';
                    } else {
                      prevBtn.disabled = false;
                      prevBtn.style.opacity = '1';
                      prevBtn.style.cursor = 'pointer';
                    }

                    if (currentYear === 2026 && currentMonth === 8) {
                      nextBtn.disabled = true;
                      nextBtn.style.opacity = '0.3';
                      nextBtn.style.cursor = 'not-allowed';
                    } else {
                      nextBtn.disabled = false;
                      nextBtn.style.opacity = '1';
                      nextBtn.style.cursor = 'pointer';
                    }
                  }

                  function changeCalendarMonth(delta) {
                    currentMonth += delta;
                    if (currentMonth < 0) {
                      currentMonth = 11;
                      currentYear -= 1;
                    } else if (currentMonth > 11) {
                      currentMonth = 0;
                      currentYear += 1;
                    }
                    drawCalendar();
                  }

                  // Bind change listener if center selection is a dropdown
                  const centerSelect = document.getElementById('centerId');
                  if (centerSelect && centerSelect.tagName === 'SELECT') {
                    centerSelect.addEventListener('change', handleCenterChange);
                  }

                  // Initialize
                  window.addEventListener('DOMContentLoaded', () => {
                    const select = document.getElementById('centerId');
                    if (select && select.tagName === 'SELECT' && select.options.length === 2) {
                      select.selectedIndex = 1;
                    }
                    handleCenterChange();
                    drawCalendar();

                    // Scroll to active date row in history table
                    const activeRow = document.querySelector('.data-table tr.highlight');
                    if (activeRow) {
                      const container = activeRow.closest('.table-responsive');
                      if (container) {
                        const containerHeight = container.clientHeight;
                        const rowTop = activeRow.offsetTop;
                        const rowHeight = activeRow.offsetHeight;
                        container.scrollTop = rowTop - (containerHeight / 2) + (rowHeight / 2);
                      }
                    }

                    // Initialize client-side table pagination
                    updateTablePagination('general');
                    updateTablePagination('workplace');
                    updateTablePagination('byt');
                  });

                  // Client-side pagination logic
                  const paginationState = {
                    general: { currentPage: 1, pageSize: 5 },
                    workplace: { currentPage: 1, pageSize: 5 },
                    byt: { currentPage: 1, pageSize: 5 }
                  };

                  function updateTablePagination(type) {
                    const tbody = document.getElementById(type + '-table-body');
                    if (!tbody) return;
                    const rows = Array.from(tbody.querySelectorAll('tr'));

                    const infoSpan = document.getElementById(type + '-page-info');
                    const prevBtn = document.getElementById(type + '-prev-btn');
                    const nextBtn = document.getElementById(type + '-next-btn');

                    // If no records or empty indicator row
                    if (rows.length === 0 || (rows.length === 1 && rows[0].cells.length <= 1)) {
                      if (infoSpan) infoSpan.style.display = 'none';
                      if (prevBtn) prevBtn.style.display = 'none';
                      if (nextBtn) nextBtn.style.display = 'none';
                      return;
                    }

                    const state = paginationState[type];
                    const totalPages = Math.ceil(rows.length / state.pageSize) || 1;

                    if (state.currentPage < 1) state.currentPage = 1;
                    if (state.currentPage > totalPages) state.currentPage = totalPages;

                    rows.forEach((row, idx) => {
                      const startIdx = (state.currentPage - 1) * state.pageSize;
                      const endIdx = startIdx + state.pageSize;
                      if (idx >= startIdx && idx < endIdx) {
                        row.style.display = '';
                      } else {
                        row.style.display = 'none';
                      }
                    });

                    if (infoSpan) infoSpan.textContent = `Trang ${state.currentPage} / ${totalPages} (Tổng ${rows.length})`;
                    if (prevBtn) prevBtn.disabled = state.currentPage === 1;
                    if (nextBtn) nextBtn.disabled = state.currentPage === totalPages;
                  }

                  function prevPage(type) {
                    if (paginationState[type].currentPage > 1) {
                      paginationState[type].currentPage--;
                      updateTablePagination(type);
                    }
                  }

                  function nextPage(type) {
                    const tbody = document.getElementById(type + '-table-body');
                    const rows = tbody ? tbody.querySelectorAll('tr') : [];
                    const totalPages = Math.ceil(rows.length / paginationState[type].pageSize) || 1;
                    if (paginationState[type].currentPage < totalPages) {
                      paginationState[type].currentPage++;
                      updateTablePagination(type);
                    }
                  }
                </script>

