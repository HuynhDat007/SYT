                      under6El.value = matched.under6;
                      document.getElementById('from6To18').value = matched.from6To18;
                      document.getElementById('over18').value = matched.over18;
                    } else {
                      under6El.value = '0';
                      document.getElementById('from6To18').value = '0';
                      document.getElementById('over18').value = '0';
                    }
                  }

                  function editAdminGeneralReport(id, unitId, centerId, dateVal, under6, from6To18, over18) {
                    document.getElementById('generalReportId').value = id;
                    const unitSelect = document.getElementById('generalUnitId');
                    if (unitSelect) {
                      unitSelect.value = unitId;
                      // Trigger change event to filter centers
                      const event = new Event('change');
                      unitSelect.dispatchEvent(event);
                    }
                    document.getElementById('generalDate').value = dateVal;
                    document.getElementById('generalCenterId').value = centerId;
                    document.getElementById('generalUnder6').value = under6;
