            <script id="timeline-labels-data" type="application/json">
                  <%- progressTimelineLabels %>
                </script>

            <script id="timeline-data-data" type="application/json">
                  <%- progressTimelineData %>
                </script>

            <script>
              const MOMO_FONT_BASE64 = "<%= momoFontBase64 %>";
              // Draw Top 5 Completion Rate Chart
              const topUnitsData = JSON.parse(document.getElementById('top-units-data').textContent);
              const ctxCompletion = document.getElementById('completionChart').getContext('2d');

              const chartGridColor = document.documentElement.classList.contains('light-theme') ? 'rgba(0, 0, 0, 0.05)' : 'rgba(255, 255, 255, 0.05)';
              const chartTextColor = document.documentElement.classList.contains('light-theme') ? '#475569' : '#94a3b8';

              window.completionChart = new Chart(ctxCompletion, {
                type: 'bar',
                plugins: [{
                  id: 'datalabels',
                  afterDatasetsDraw(chart, args, options) {
                    const { ctx } = chart;
                    ctx.save();
                    ctx.font = 'bold 11px Inter, system-ui';
                    ctx.textAlign = 'center';
                    ctx.textBaseline = 'bottom';
                    chart.data.datasets.forEach((dataset, i) => {
                      chart.getDatasetMeta(i).data.forEach((bar, index) => {
                        const value = dataset.data[index];
                        const valueString = value.toFixed(1) + '%';
                        ctx.fillStyle = document.documentElement.classList.contains('light-theme') ? '#0f172a' : '#f8fafc';
                        ctx.fillText(valueString, bar.x, bar.y - 5);
                      });
                    });
                    ctx.restore();
                  }
                }],
                data: {
                  labels: topUnitsData.map(u => u.name),
                  datasets: [{
                    label: 'Tỷ lệ hoàn thành (%)',
                    data: topUnitsData.map(u => u.rate),
                    backgroundColor: [
                      'rgba(0, 242, 254, 0.8)',
                      'rgba(6, 182, 212, 0.8)',
                      'rgba(16, 185, 129, 0.8)',
                      'rgba(59, 130, 246, 0.8)',
                      'rgba(251, 191, 36, 0.8)'
                    ],
                    borderColor: [
                      '#00f2fe',
                      '#06b6d4',
                      '#10b981',
                      '#3b82f6',
                      '#fbbf24'
                    ],
                    borderWidth: 1.5,
                    borderRadius: 6
                  }]
                },
                options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  plugins: {
                    legend: { display: false },
                    tooltip: {
                      callbacks: {
                        label: function (context) {
                          return 'Tỷ lệ: ' + context.parsed.y.toFixed(2) + '%';
                        }
                      }
                    }
                  },
                  scales: {
                    y: {
                      beginAtZero: true,
                      grace: '8%',
                      grid: { color: chartGridColor },
                      ticks: { color: chartTextColor }
                    },
                    x: {
                      grid: { display: false },
                      ticks: { color: chartTextColor }
                    }
                  }
                }
              });

              // Draw Cumulative Timeline Chart
              const timelineLabels = JSON.parse(document.getElementById('timeline-labels-data').textContent);
              const timelineData = JSON.parse(document.getElementById('timeline-data-data').textContent);
              const ctxTimeline = document.getElementById('timelineChart').getContext('2d');

              window.timelineChart = new Chart(ctxTimeline, {
                type: 'line',
                plugins: [{
                  id: 'timelineDatalabels',
                  afterDatasetsDraw(chart, args, options) {
                    const { ctx } = chart;
                    ctx.save();
                    ctx.font = 'bold 10px Inter, system-ui';
                    ctx.textAlign = 'center';
                    ctx.textBaseline = 'bottom';
                    chart.data.datasets.forEach((dataset, i) => {
                      const meta = chart.getDatasetMeta(i);
                      meta.data.forEach((point, index) => {
                        const value = dataset.data[index];
                        if (value === 0) return;

                        const totalPoints = dataset.data.length;
                        // If many points exist, draw labels at intervals of 5 to avoid overlap, but always draw the last point
                        if (totalPoints > 15 && index % 5 !== 0 && index !== totalPoints - 1) {
                          return;
                        }

                        const valueString = value.toLocaleString('vi-VN');
                        ctx.fillStyle = document.documentElement.classList.contains('light-theme') ? '#0f172a' : '#f8fafc';
                        ctx.fillText(valueString, point.x, point.y - 6);
                      });
                    });
                    ctx.restore();
                  }
                }],
                data: {
                  labels: timelineLabels,
                  datasets: [{
                    label: 'Lũy kế toàn tỉnh',
                    data: timelineData,
                    fill: true,
                    backgroundColor: document.documentElement.classList.contains('light-theme') ? 'rgba(2, 132, 199, 0.05)' : 'rgba(0, 242, 254, 0.05)',
                    borderColor: document.documentElement.classList.contains('light-theme') ? '#0284c7' : '#00f2fe',
                    borderWidth: 2,
                    tension: 0.3,
                    pointBackgroundColor: document.documentElement.classList.contains('light-theme') ? '#0284c7' : '#00f2fe',
                    pointRadius: timelineData.length > 20 ? 2 : 4,
                    pointHoverRadius: 6
                  }]
                },
                options: {
                  responsive: true,
                  maintainAspectRatio: false,
                  plugins: {
                    legend: { display: false }
                  },
                  scales: {
                    y: {
                      beginAtZero: true,
                      grace: '10%',
                      grid: { color: chartGridColor },
                      ticks: { color: chartTextColor }
                    },
                    x: {
                      grid: { display: false },
                      ticks: { color: chartTextColor }
                    }
                  }
                }
              });

              // Multi-select Dropdown Table Filtering Logic
              document.addEventListener('DOMContentLoaded', () => {
                const trigger = document.getElementById('multiselect-trigger');
                const dropdown = document.getElementById('multiselect-dropdown');
                const arrow = document.getElementById('multiselect-arrow');
                const searchInput = document.getElementById('multiselect-search');
                const label = document.getElementById('multiselect-value');
                const selectAllBtn = document.getElementById('multiselect-select-all');
                const deselectAllBtn = document.getElementById('multiselect-deselect-all');
                const checkboxes = document.querySelectorAll('.multiselect-checkbox');
                const tableRows = document.querySelectorAll('#units-table tbody tr');

                if (!trigger || !dropdown) return;

                // Toggle dropdown visibility
                trigger.addEventListener('click', (e) => {
                  e.stopPropagation();
                  const isOpen = dropdown.style.display === 'block';
                  dropdown.style.display = isOpen ? 'none' : 'block';
                  arrow.style.transform = isOpen ? 'rotate(0deg)' : 'rotate(180deg)';
                });

                // Close dropdown when clicking outside
                document.addEventListener('click', (e) => {
                  if (!dropdown.contains(e.target) && !trigger.contains(e.target)) {
                    dropdown.style.display = 'none';
                    arrow.style.transform = 'rotate(0deg)';
                  }
                });

                // Search filter inside dropdown checklist options
                searchInput.addEventListener('keyup', () => {
                  const query = searchInput.value.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[đĐ]/g, 'd');
                  const items = document.querySelectorAll('.multiselect-option-item');
                  items.forEach(item => {
                    const text = item.querySelector('label').textContent.toLowerCase().normalize('NFD').replace(/[\u0300-\u036f]/g, '').replace(/[đĐ]/g, 'd');
                    if (text.indexOf(query) > -1) {
                      item.style.display = 'flex';
                    } else {
                      item.style.display = 'none';
                    }
                  });
                });

                // Function to apply filters to the table rows and update status label
                function filterTable() {
                  const checkedBoxes = Array.from(checkboxes).filter(cb => cb.checked);
                  const totalUnits = checkboxes.length;

                  // Update label text
                  if (checkedBoxes.length === totalUnits) {
                    label.textContent = `Tất cả đơn vị (${totalUnits})`;
                  } else if (checkedBoxes.length === 0) {
                    label.textContent = 'Chưa chọn đơn vị nào';
                  } else {
                    const names = checkedBoxes.map(cb => cb.value);
                    if (names.length <= 2) {
                      label.textContent = names.join(', ');
                    } else {
                      label.textContent = `Đã chọn ${checkedBoxes.length} đơn vị`;
                    }
                  }

                  // Hide or show table rows based on checks
                  const checkedNames = checkedBoxes.map(cb => cb.value.trim());
                  tableRows.forEach(row => {
                    const unitCell = row.cells[1];
                    if (unitCell) {
                      // Extract plain text (ignoring potential badge elements)
                      const unitName = unitCell.childNodes[0].textContent.trim();
                      if (checkedBoxes.length === totalUnits || checkedNames.includes(unitName)) {
                        row.style.display = '';
                      } else {
                        row.style.display = 'none';
                      }
                    }
                  });
                }

                // Checkbox toggle listener
                checkboxes.forEach(cb => {
                  cb.addEventListener('change', filterTable);
                });

                // Select All action button
                selectAllBtn.addEventListener('click', () => {
                  checkboxes.forEach(cb => {
                    cb.checked = true;
                  });
                  filterTable();
                });

                // Deselect All action button
                deselectAllBtn.addEventListener('click', () => {
                  checkboxes.forEach(cb => {
                    cb.checked = false;
                  });
                  filterTable();
                });

                // Switch table display modes client-side
                window.switchTableMode = function (mode) {
                  const monthCols = document.querySelectorAll('.col-month');
                  const dayCols = document.querySelectorAll('.col-day');
                  const btnMonth = document.getElementById('btn-mode-month');
                  const btnDay = document.getElementById('btn-mode-day');

                  if (mode === 'month') {
                    monthCols.forEach(el => el.style.display = '');
                    dayCols.forEach(el => el.style.display = 'none');

                    btnMonth.style.background = 'var(--primary-color)';
                    btnMonth.style.color = '#ffffff';
                    btnDay.style.background = 'transparent';
                    btnDay.style.color = 'var(--text-secondary)';
                  } else {
                    monthCols.forEach(el => el.style.display = 'none');
                    dayCols.forEach(el => el.style.display = '');

                    btnMonth.style.background = 'transparent';
                    btnMonth.style.color = 'var(--text-secondary)';
                    btnDay.style.background = 'var(--primary-color)';
                    btnDay.style.color = '#ffffff';

                    // Auto-scroll to current day column
                    setTimeout(() => {
                      const targetStr = '<%= dailyMatchDateStr %>';
                      const targetCol = document.getElementById('col-day-' + targetStr);
                      if (targetCol) {
                        const container = targetCol.closest('.table-responsive');
                        if (container) {
                          container.scrollTo({
                            left: targetCol.offsetLeft - container.offsetWidth / 2 + targetCol.offsetWidth / 2,
                            behavior: 'smooth'
                          });
                        }
                      }
                    }, 150);
                  }
                };


                // Download report as PNG
                window.downloadFigmaReportPng = function () {
                  const svgEl = document.querySelector('#report-canvas-wrapper svg');
                  if (!svgEl) return;

                  const serializer = new XMLSerializer();
                  let source = serializer.serializeToString(svgEl);

                  // Inline the base64 font styles so the browser can resolve custom fonts offline/canvas
                  const fontStyle = `
<defs>
  <style type="text/css">
    @font-face {
      font-family: 'Momo Trust Display';
      src: url('data:application/x-font-ttf;charset=utf-8;base64,${MOMO_FONT_BASE64}') format('truetype');
    }
    @font-face {
      font-family: 'Momo Trust Display Web';
      src: url('data:application/x-font-ttf;charset=utf-8;base64,${MOMO_FONT_BASE64}') format('truetype');
    }
  </style>
</defs>
`;
                  source = source.replace(/<svg([^>]*)>/, `<svg$1>${fontStyle}`);

                  const img = new Image();
                  const blob = new Blob([source], { type: 'image/svg+xml;charset=utf-8' });
                  const url = URL.createObjectURL(blob);

                  img.onload = function () {
                    const canvas = document.createElement('canvas');
                    canvas.width = 2480;
                    canvas.height = 3508;
                    const ctx = canvas.getContext('2d');

                    ctx.fillStyle = '#ffffff';
                    ctx.fillRect(0, 0, canvas.width, canvas.height);

                    ctx.drawImage(img, 0, 0, canvas.width, canvas.height);

                    try {
                      canvas.toBlob(function (pngBlob) {
                        const pngUrl = URL.createObjectURL(pngBlob);
                        const link = document.createElement("a");
                        link.href = pngUrl;
                        link.download = `bao-cao-syt-figma-${document.getElementById('dashboard-date-picker').value}.png`;
                        document.body.appendChild(link);
                        link.click();
                        document.body.removeChild(link);
                        URL.revokeObjectURL(pngUrl);
                        URL.revokeObjectURL(url);
                      }, 'image/png');
                    } catch (e) {
                      console.error('toBlob failed, falling back to data URL', e);
                      const pngUrl = canvas.toDataURL('image/png');
                      const link = document.createElement("a");
                      link.href = pngUrl;
                      link.download = `bao-cao-syt-figma-${document.getElementById('dashboard-date-picker').value}.png`;
                      document.body.appendChild(link);
                      link.click();
                      document.body.removeChild(link);
                      URL.revokeObjectURL(url);
                    }
                  };

                  img.src = url;
                };

                // Print report in a dedicated printable tab
                window.printFigmaReport = function () {
                  window.open('/report?date=<%= dailyMatchDateStr %>&print=true', '_blank');
                };

                // Initial filter run
                filterTable();
              });
            </script>

            <%- include('partials/footer') %>