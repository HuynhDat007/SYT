                    const sRow = worksheet.addRow(summaryValues);
                    sRow.height = 24;
                    const sRowIdx = sRow.number;

                    worksheet.mergeCells(sRowIdx, 1, sRowIdx, 2);

                    const summaryBorder = {
                      top: { style: 'medium', color: { argb: 'FF0284C7' } },
                      left: { style: 'thin', color: { argb: 'FFCBD5E1' } },
