<%- include('partials/header') %>

  <style>
    @font-face {
      font-family: 'Momo Trust Display Web';
      src: url('/css/MomoTrustDisplay-Regular.ttf?v=2') format('truetype');
      font-weight: normal;
      font-style: normal;
      font-display: swap;
    }

    .report-canvas-wrapper svg {
      width: 100%;
      height: 100%;
    }

    .report-canvas-wrapper svg text,
    .report-canvas-wrapper svg tspan {
      font-family: 'Momo Trust Display Web', sans-serif !important;
      paint-order: stroke fill;
    }

    .report-canvas-wrapper svg .center-text,
    .report-canvas-wrapper svg .center-text tspan {
      text-anchor: middle !important;
      white-space: normal !important;
    }
  </style>

  <div class="page-title-section"
    style="display: flex; justify-content: space-between; align-items: center; width: 100%; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
    <h1 class="page-title" style="margin: 0;">
      <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)"
        stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" style="width: 28px; height: 28px;">
        <rect x="3" y="3" width="7" height="9" />
        <rect x="14" y="3" width="7" height="5" />
        <rect x="14" y="12" width="7" height="9" />
        <rect x="3" y="16" width="7" height="5" />
      </svg>
      Báo Cáo Tổng Quan Số Liệu Khám Sức Khỏe
    </h1>
  </div>

  <!-- Stats Dashboard Row -->
  <div class="stats-grid">
    <!-- Card 1: Lượt người khám trong ngày -->
    <div class="glass-panel stat-card">
      <div class="stat-icon green">
        <!-- Calendar day SVG -->
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <rect x="3" y="4" width="18" height="18" rx="2" ry="2" />
          <line x1="16" y1="2" x2="16" y2="6" />
          <line x1="8" y1="2" x2="8" y2="6" />
          <line x1="3" y1="10" x2="21" y2="10" />
        </svg>
      </div>
      <div class="stat-info">
        <span class="stat-label">Lượt người khám trong ngày</span>
        <span class="stat-number">
          <%= grandDaily.total.toLocaleString('vi-VN') %>
        </span>
        <span style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.2rem;">Ngày <%=
            dailyMatchDateStr.split('-').reverse().join('/') %></span>
      </div>
    </div>

    <!-- Card 2: Lũy kế toàn tỉnh(01/07 - hiện nay) -->
    <div class="glass-panel stat-card">
      <div class="stat-icon primary">
        <!-- Activity SVG -->
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <polyline points="22 12 18 12 15 21 9 3 6 12 2 12" />
        </svg>
      </div>
      <div class="stat-info">
        <span class="stat-label">Lũy kế toàn tỉnh (01/07 - hiện tại)</span>
        <span class="stat-number">
          <%= grandCumulative.total.toLocaleString('vi-VN') %>
        </span>
        <span style="font-size: 0.8rem; color: var(--text-secondary); margin-top: 0.2rem;">Chiến dịch 90 ngày</span>
      </div>
    </div>

    <!-- Card 3: Tổng số người đã kSK 6 tháng đầu năm -->
    <div class="glass-panel stat-card">
      <div class="stat-icon yellow">
        <!-- Users checkup SVG -->
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" />
          <circle cx="9" cy="7" r="4" />
          <path d="M23 21v-2a4 4 0 0 0-3-3.87" />
          <path d="M16 3.13a4 4 0 0 1 0 7.75" />
        </svg>
      </div>
      <div class="stat-info">
        <span class="stat-label">Số Đã KSK 6 tháng đầu năm</span>
        <span class="stat-number">
          <%= grandFirstHalfChecked.toLocaleString('vi-VN') %>
        </span>
        <span style="font-size: 0.8rem; color: transparent; margin-top: 0.2rem; user-select: none;">&nbsp;</span>
      </div>
    </div>

    <!-- Card 4: Số người đã KSK toàn tỉnh -->
    <div class="glass-panel stat-card">
      <div class="stat-icon primary">
        <!-- Check list SVG -->
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5">
          <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14" />
          <polyline points="22 4 12 14.01 9 11.01" />
        </svg>
      </div>
      <div class="stat-info">
        <span class="stat-label">Số đã KSK toàn tỉnh</span>
        <span class="stat-number">
          <%= grandYearCumulative.toLocaleString('vi-VN') %>
        </span>
        <span style="font-size: 0.8rem; color: transparent; margin-top: 0.2rem; user-select: none;">&nbsp;</span>
      </div>
    </div>
  </div>
  <% if (dashboardNoteVisible) { %>
    <div style="font-size: 0.88rem; color: var(--text-secondary); font-style: italic; white-space: pre-line;">
      <%= dashboardNoteText %>
    </div>
    <% } %>
      <!-- Figma A4 Report Section -->
      <div class="glass-panel" id="figma-report-panel" style="margin-bottom: 2rem; scroll-margin-top: 5rem;">
        <div
          style="display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--panel-border); padding-bottom: 1rem; margin-bottom: 1.5rem; flex-wrap: wrap; gap: 1rem;">
          <h3
            style="font-size: 1.2rem; font-weight: 700; margin: 0; display: flex; align-items: center; gap: 0.5rem; color: var(--primary-color);">
            <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
              <polyline points="14 2 14 8 20 8" />
              <line x1="16" y1="13" x2="8" y2="13" />
              <line x1="16" y1="17" x2="8" y2="17" />
              <polyline points="10 9 9 9 8 9" />
            </svg>
            Báo cáo ngày
            <div
              style="position: relative; display: inline-block; vertical-align: middle; margin-left: 0.25rem; cursor: pointer;"
              onclick="try { document.getElementById('dashboard-date-picker').showPicker() } catch(e) {}">
              <span
                style="display: inline-flex; align-items: center; gap: 0.35rem; padding: 0.25rem 0.5rem; font-size: 1.1rem; font-weight: 700; border: 1px solid var(--panel-border); border-radius: 6px; color: var(--primary-color); background: var(--bg-card); pointer-events: none;">
                <%= dailyMatchDateStr.split('-').reverse().join('/') %>
                  <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"
                    style="margin-left: 0.2rem; opacity: 0.8;">
                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                    <line x1="16" y1="2" x2="16" y2="6"></line>
                    <line x1="8" y1="2" x2="8" y2="6"></line>
                    <line x1="3" y1="10" x2="21" y2="10"></line>
                  </svg>
              </span>
              <input type="date" id="dashboard-date-picker" value="<%= dailyMatchDateStr %>"
                onchange="window.location.href='/?date=' + this.value"
                style="position: absolute; left: 0; top: 0; width: 100%; height: 100%; opacity: 0; cursor: pointer; z-index: 10; pointer-events: none;">
            </div>
          </h3>

          <div style="display: flex; gap: 0.75rem;">
            <!-- Download PNG Button -->
            <button class="btn btn-secondary" onclick="downloadFigmaReportPng()"
              style="padding: 0.5rem 1rem; font-size: 0.82rem; font-weight: 600; display: flex; align-items: center; gap: 0.35rem; background-color: #007bff; border-color: #007bff; color: white;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4" />
                <polyline points="7 10 12 15 17 10" />
                <line x1="12" y1="15" x2="12" y2="3" />
              </svg>
              Tải file PNG (Ảnh)
            </button>
            <!-- Print Button -->
            <button class="btn btn-primary" onclick="printFigmaReport()"
              style="padding: 0.5rem 1rem; font-size: 0.82rem; font-weight: 600; display: flex; align-items: center; gap: 0.35rem;">
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                <polyline points="6 9 6 2 18 2 18 9" />
                <path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2" />
                <rect x="6" y="14" width="12" height="8" />
              </svg>
              In Báo cáo
            </button>
          </div>
        </div>

        <!-- Interactive Report container with customized fonts and scaling -->
        <div style="display: flex; justify-content: center; width: 100%; overflow: auto; padding: 1rem 0;">
          <div class="report-canvas-wrapper" id="report-canvas-wrapper"
            style="box-shadow: 0 4px 30px rgba(0,0,0,0.15); background: white; border-radius: 8px; width: 100%; max-width: 900px; aspect-ratio: 1 / 1.414; display: flex; justify-content: center; align-items: center; border: 1px solid var(--panel-border);">
            <%- svgContent %>
          </div>
        </div>
      </div>

      <!-- Table: Thống kê KSK các cơ quan trong hệ thống chính trị -->
      <% if (typeof dashboardPoliticalReports !=='undefined' ) { %>
        <div class="glass-panel" style="margin-bottom: 2rem;">
          <h3
            style="font-size: 1.15rem; font-weight: 700; margin-bottom: 1.25rem; display: flex; align-items: center; gap: 0.5rem; color: var(--primary-color);">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z" />
            </svg>
            THỐNG KÊ KSK CÁC CQ TRONG HỆ THỐNG CHÍNH TRỊ
          </h3>

          <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
            <table class="table" style="width: 100%; border-collapse: collapse; min-width: 600px;">
              <thead>
                <tr
                  style="border-bottom: 2px solid var(--panel-border); text-align: left; font-size: 0.85rem; font-weight: 600; color: var(--text-secondary);">
                  <th class="sticky-thead"
                    style="padding: 0.75rem 0.5rem; width: 50px; text-align: center; border-right: 1px solid var(--panel-border);">
                    STT</th>
                  <th class="sticky-thead" style="padding: 0.75rem 0.5rem; border-right: 1px solid var(--panel-border);">Tên cơ quan, đơn vị
                  </th>
                  <th class="sticky-thead" style="padding: 0.75rem 0.5rem; text-align: center; border-right: 1px solid var(--panel-border);">Số
                    CBCC CV NLĐ</th>
                  <th class="sticky-thead" style="padding: 0.75rem 0.5rem; text-align: center; border-right: 1px solid var(--panel-border);">Số
                    đã KSK</th>
                  <th class="sticky-thead" style="padding: 0.75rem 0.5rem; text-align: center; width: 120px;">Ngày báo cáo</th>
                </tr>
              </thead>
              <tbody>
                <% if (dashboardPoliticalReports.length> 0) { %>
                  <% dashboardPoliticalReports.forEach((r, idx)=> { %>
                    <% const rDate=new Date(r.date); const rDateStr=`${String(rDate.getUTCDate()).padStart(2, '0'
                      )}/${String(rDate.getUTCMonth() + 1).padStart(2, '0' )}/${rDate.getUTCFullYear()}`; %>
                      <tr style="border-bottom: 1px solid var(--panel-border); font-size: 0.9rem;">
                        <td
                          style="padding: 0.75rem 0.5rem; text-align: center; border-right: 1px solid var(--panel-border);">
                          <%= idx + 1 %>
                        </td>
                        <td
                          style="padding: 0.75rem 0.5rem; font-weight: 600; border-right: 1px solid var(--panel-border);">
                          <%= r.adminWorkplace %>
                        </td>
                        <td
                          style="padding: 0.75rem 0.5rem; text-align: center; border-right: 1px solid var(--panel-border);">
                          <%= (r.adminWorkers || 0).toLocaleString('vi-VN') %>
                        </td>
                        <td
                          style="padding: 0.75rem 0.5rem; text-align: center; font-weight: 700; color: var(--primary-color); border-right: 1px solid var(--panel-border);">
                          <%= (r.adminPolitical || 0).toLocaleString('vi-VN') %>
                        </td>
                        <td style="padding: 0.75rem 0.5rem; text-align: center; color: var(--text-secondary);">
                          <%= rDateStr %>
                        </td>
                      </tr>
                      <% }) %>
                        <% } else { %>
                          <tr>
                            <td colspan="5"
                              style="text-align: center; color: var(--text-secondary); padding: 1.5rem; font-size: 0.9rem;">
                              Không có dữ liệu báo cáo cơ quan chính trị.
                            </td>
                          </tr>
                          <% } %>
              </tbody>
            </table>
          </div>
        </div>
        <% } %>


          <!-- Charts Grid -->
          <div class="charts-grid" style="display: none;">
            <!-- Bar chart of top units -->
            <div class="glass-panel chart-panel">
              <h3 class="chart-title">
                <!-- Award SVG -->
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)"
                  stroke-width="2">
                  <circle cx="12" cy="8" r="7" />
                  <polyline points="8.21 13.89 7 23 12 20 17 23 15.79 13.88" />
                </svg>
                Top 5 Đơn Vị Dẫn Đầu Tiến Độ
              </h3>
              <div style="position: relative; height: 260px; width: 100%;">
                <canvas id="completionChart"></canvas>
              </div>
            </div>

            <!-- Progress timeline chart -->
            <div class="glass-panel chart-panel">
              <h3 class="chart-title">
                <!-- Line chart SVG -->
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="var(--primary-color)"
                  stroke-width="2">
                  <path d="M3 3v18h18" />
                  <path d="M18.7 8l-5.1 5.2-2.8-2.7L7 14.3" />
                </svg>
                Biểu Đồ Lũy Kế Lượt Khám Toàn Tỉnh
              </h3>
              <div style="position: relative; height: 260px; width: 100%;">
                <canvas id="timelineChart"></canvas>
              </div>
            </div>
          </div>

          <!-- Detailed Table Board -->
          <div class="glass-panel">
            <div
              style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem; flex-wrap: wrap; gap: 1rem;">
              <h3
                style="font-size: 1.2rem; font-weight: 700; display: flex; align-items: center; gap: 0.5rem; color: var(--primary-color);">
                <!-- Table SVG -->
                <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                  <rect x="3" y="3" width="18" height="18" rx="2" ry="2" />
                  <line x1="3" y1="9" x2="21" y2="9" />
                  <line x1="3" y1="15" x2="21" y2="15" />
                  <line x1="12" y1="3" x2="12" y2="21" />
                </svg>
                Bảng Thống Kê Chi Tiết 96 Xã / Phường
              </h3>

              <div style="display: flex; gap: 1rem; align-items: center; flex-wrap: wrap;">
                <!-- Toggle Mode Segment Controller -->
                <div
                  style="display: flex; align-items: center; gap: 0.25rem; background: var(--input-bg); padding: 0.25rem; border-radius: 8px; border: 1px solid var(--panel-border);">
                  <button type="button" class="btn segment-btn" id="btn-mode-month"
                    style="padding: 0.35rem 0.75rem; font-size: 0.8rem; border-radius: 6px; border: none; font-weight: 600; cursor: pointer; transition: all 0.2s ease; background: var(--primary-color); color: #ffffff;"
                    onclick="switchTableMode('month')">
                    Thống kê Tháng
                  </button>
                  <button type="button" class="btn segment-btn" id="btn-mode-day"
                    style="padding: 0.35rem 0.75rem; font-size: 0.8rem; border-radius: 6px; border: none; font-weight: 600; cursor: pointer; transition: all 0.2s ease; background: transparent; color: var(--text-secondary);"
                    onclick="switchTableMode('day')">
                    Số liệu trong Ngày
                  </button>
                </div>



                <!-- Custom Multi-select Dropdown -->
                <div class="multiselect-container" style="position: relative; width: 280px;">
                  <div class="form-control multiselect-trigger" id="multiselect-trigger"
                    style="display: flex; justify-content: space-between; align-items: center; cursor: pointer; padding-right: 1rem; user-select: none; border-radius: 8px; border: 1px solid var(--input-border); background: var(--input-bg); min-height: 42px;">
                    <span id="multiselect-value"
                      style="color: var(--text-secondary); font-size: 0.85rem; overflow: hidden; text-overflow: ellipsis; white-space: nowrap; max-width: 250px;">Tất
                      cả đơn vị (96)</span>
                    <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3"
                      style="transition: transform 0.2s ease;" id="multiselect-arrow">
                      <polyline points="6 9 12 15 18 9" />
                    </svg>
                  </div>

                  <div class="multiselect-dropdown" id="multiselect-dropdown"
                    style="display: none; position: absolute; top: 100%; left: 0; right: 0; margin-top: 0.5rem; z-index: 500; padding: 1rem; border-radius: 12px; background: var(--panel-bg); backdrop-filter: blur(12px); border: 1px solid var(--panel-border); box-shadow: var(--panel-shadow);">
                    <!-- Dropdown search input -->
                    <div class="input-wrapper" style="margin-bottom: 0.75rem;">
                      <div class="input-icon">
                        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                          stroke-width="2">
                          <circle cx="11" cy="11" r="8" />
                          <line x1="21" y1="21" x2="16.65" y2="16.65" />
                        </svg>
                      </div>
                      <input type="text" id="multiselect-search" class="form-control" placeholder="Tìm kiếm đơn vị..."
                        style="font-size: 0.8rem; padding-top: 0.4rem; padding-bottom: 0.4rem; height: auto;">
                    </div>

                    <!-- Quick actions: Select All / Deselect All -->
                    <div
                      style="display: flex; gap: 0.5rem; justify-content: space-between; margin-bottom: 0.75rem; font-size: 0.75rem;">
                      <button type="button" class="btn btn-secondary" id="multiselect-select-all"
                        style="padding: 0.25rem 0.5rem; font-size: 0.7rem; border-radius: 4px; flex: 1;">Chọn tất
                        cả</button>
                      <button type="button" class="btn btn-secondary" id="multiselect-deselect-all"
                        style="padding: 0.25rem 0.5rem; font-size: 0.7rem; border-radius: 4px; flex: 1;">Bỏ chọn tất
                        cả</button>
                    </div>

                    <!-- Checkbox list options -->
                    <div class="multiselect-options" id="multiselect-options"
                      style="max-height: 250px; overflow-y: auto; display: flex; flex-direction: column; gap: 0.4rem; padding-right: 0.25rem;">
                      <% reportsTable.forEach((row, index)=> { %>
                        <div class="multiselect-option-item"
                          style="display: flex; align-items: center; gap: 0.5rem; cursor: pointer; padding: 0.15rem 0;">
                          <input type="checkbox" class="multiselect-checkbox" id="chk-unit-<%= row.unitId %>"
                            value="<%= row.unitName %>" checked
                            style="cursor: pointer; accent-color: var(--primary-color);">
                          <label for="chk-unit-<%= row.unitId %>"
                            style="cursor: pointer; font-size: 0.85rem; user-select: none; color: var(--text-primary);">
                            <%= row.unitName %>
                          </label>
                        </div>
                        <% }) %>
                    </div>
                  </div>
                </div>
              </div>

              <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                <table class="data-table" id="units-table">
                  <thead>
                    <tr>
                      <th rowspan="2" class="col-sticky-1"
                        style="vertical-align: middle; text-align: center; min-width: 50px; max-width: 50px; width: 50px; position: sticky; top: 0; left: 0; z-index: 30;">
                        STT</th>
                      <th rowspan="2" class="col-sticky-2"
                        style="vertical-align: middle; text-align: left; min-width: 170px; max-width: 170px; width: 170px; position: sticky; top: 0; left: 50px; z-index: 30;">
                        Tên xã phường</th>
                      <th rowspan="2"
                        style="vertical-align: middle; text-align: center; white-space: normal; min-width: 90px; max-width: 90px; line-height: 1.2;">
                        Tổng nhân<br>khẩu</th>
                      <th rowspan="2"
                        style="vertical-align: middle; text-align: center; white-space: normal; min-width: 130px; max-width: 130px; line-height: 1.2;">
                        Nhân khẩu địa<br>phương quản lý</th>
                      <th rowspan="2"
                        style="vertical-align: middle; text-align: center; white-space: normal; min-width: 130px; max-width: 130px; line-height: 1.2;">
                        Số người khám<br>6 tháng đầu năm</th>
                      <th rowspan="2"
                        style="vertical-align: middle; text-align: center; white-space: normal; min-width: 110px; max-width: 110px; line-height: 1.2;">
                        Số người cần<br>khám 90 ngày</th>
                      <th rowspan="2"
                        style="vertical-align: middle; text-align: center; white-space: normal; min-width: 120px; max-width: 120px; line-height: 1.2;">
                        Số người đã KSK<br>trong 90 ngày</th>
                      <th rowspan="2"
                        style="vertical-align: middle; text-align: center; white-space: normal; min-width: 120px; max-width: 120px; line-height: 1.2;">
                        Tỷ lệ hoàn thành<br>90 ngày</th>

                      <th colspan="3" class="col-month"
                        style="text-align: center; background: var(--month-7-bg); border-bottom: 2px solid var(--primary-color);">
                        Tháng 7</th>
                      <th colspan="3" class="col-month"
                        style="text-align: center; background: var(--month-8-bg); border-bottom: 2px solid var(--accent-green);">
                        Tháng 8</th>
                      <th colspan="3" class="col-month"
                        style="text-align: center; background: var(--month-9-bg); border-bottom: 2px solid var(--accent-yellow);">
                        Tháng 9</th>
                      <!-- Trong Ngày (từng ngày 01/07 đến 30/09) -->
                      <% campaignDays.forEach(day=> { %>
                        <% const isCurrentDay=(day.dateStr===dailyMatchDateStr); %>
                          <th rowspan="2" class="col-day <%= isCurrentDay ? 'col-current-day' : '' %>"
                            id="col-day-<%= day.dateStr %>"
