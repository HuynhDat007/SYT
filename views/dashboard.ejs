                    ]);
                    h2Row.height = 22;

                    // Merge Main Headers (Rows 3-4)
                    for (let c = 1; c <= 8; c++) {
                      worksheet.mergeCells(3, c, 4, c);
                      const cell = worksheet.getCell(3, c);
                      cell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FF0284C7' } };
                      cell.font = { name: 'Segoe UI', size: 10, bold: true, color: { argb: 'FFFFFFFF' } };
                      cell.alignment = { horizontal: 'center', vertical: 'middle', wrapText: true };
                      cell.border = borderStyle;
                    }

                    // Month 7 Header (Cols 9-11)
                    worksheet.mergeCells(3, 9, 3, 11);
                    const m7Cell = worksheet.getCell(3, 9);
                    m7Cell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FF0284C7' } };
                    m7Cell.font = { name: 'Segoe UI', size: 10, bold: true, color: { argb: 'FFFFFFFF' } };
                    m7Cell.alignment = { horizontal: 'center', vertical: 'middle' };
                    m7Cell.border = borderStyle;

                    // Month 8 Header (Cols 12-14)
                    worksheet.mergeCells(3, 12, 3, 14);
                    const m8Cell = worksheet.getCell(3, 12);
                    m8Cell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FF059669' } };
                    m8Cell.font = { name: 'Segoe UI', size: 10, bold: true, color: { argb: 'FFFFFFFF' } };
                    m8Cell.alignment = { horizontal: 'center', vertical: 'middle' };
                    m8Cell.border = borderStyle;

                    // Month 9 Header (Cols 15-17)
                    worksheet.mergeCells(3, 15, 3, 17);
                    const m9Cell = worksheet.getCell(3, 15);
                    m9Cell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFD97706' } };
                    m9Cell.font = { name: 'Segoe UI', size: 10, bold: true, color: { argb: 'FFFFFFFF' } };
                    m9Cell.alignment = { horizontal: 'center', vertical: 'middle' };
                    m9Cell.border = borderStyle;

                    // Sub Headers (Row 4, Cols 9-17)
                    for (let c = 9; c <= 11; c++) {
                      const cell = h2Row.getCell(c);
                      cell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFE0F2FE' } };
                      cell.font = { name: 'Segoe UI', size: 9, bold: true, color: { argb: 'FF0369A1' } };
                      cell.alignment = { horizontal: 'center', vertical: 'middle' };
                      cell.border = borderStyle;
                    }
                    for (let c = 12; c <= 14; c++) {
                      const cell = h2Row.getCell(c);
