                      cell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFFEE3C7' } };
                      cell.font = { name: 'Segoe UI', size: 9, bold: true, color: { argb: 'FFB45309' } };
                      cell.alignment = { horizontal: 'center', vertical: 'middle' };
                      cell.border = borderStyle;
                    }
                  } else {
                    // Day Mode Headers
                    const dayHeaders = [];
                    dayThs.forEach(th => dayHeaders.push(th.textContent.trim()));
                    const hRow = worksheet.addRow([
                      'STT', 'Tên xã phường', 'Tổng nhân khẩu', 'Nhân khẩu địa phương quản lý',
                      'Số người khám 6 tháng đầu năm', 'Số người cần khám 90 ngày',
