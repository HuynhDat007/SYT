                      right: { style: 'thin', color: { argb: 'FFCBD5E1' } }
                    };

                    for (let c = 1; c <= totalCols; c++) {
                      const cell = sRow.getCell(c);
                      cell.fill = { type: 'pattern', pattern: 'solid', fgColor: { argb: 'FFE0F2FE' } };
                      cell.font = { name: 'Segoe UI', size: 10, bold: true, color: (c === 8 ? { argb: 'FF0284C7' } : { argb: 'FF0F172A' }) };
                      cell.border = summaryBorder;

                      if (c === 1) {
                        cell.alignment = { horizontal: 'center', vertical: 'middle' };
                      } else if (c >= 3 && c <= 7) {
                        cell.alignment = { horizontal: 'right', vertical: 'middle' };
                        cell.numFmt = '#,##0';
                      } else if (c === 8) {
                        cell.alignment = { horizontal: 'right', vertical: 'middle' };
                      } else {
                        cell.alignment = { horizontal: 'right', vertical: 'middle' };
                        cell.numFmt = '#,##0';
                      }
                    }
                  }

                  // Unit rows
                  const allUnitTrs = document.querySelectorAll('#units-table tbody tr');
                  let rowIndex = 0;
                  for (let i = 1; i < allUnitTrs.length; i++) {
                    const tr = allUnitTrs[i];
                    if (!tr || tr.style.display === 'none') continue;

                    rowIndex++;
                    const isEven = rowIndex % 2 === 0;
                    const rowBg = isEven ? 'FFF8FAFC' : 'FFFFFFFF';
                    const tds = tr.children;
                    const unitValues = [];

                    unitValues.push(tds[0] ? parseNum(tds[0].textContent) : rowIndex);

